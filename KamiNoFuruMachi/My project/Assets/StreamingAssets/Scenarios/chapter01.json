{
  "chapterId": "chapter01",
  "title": "第1話「出会い」",
  "commands": [
    { "cmd": "bgm", "id": "nainfall_ambient", "fade": 2.0 },
    { "cmd": "bg", "id": "abandoned_chapel", "transition": "fade" },
    { "cmd": "se", "id": "steam_pipe" },
    { "cmd": "text", "char": "narrator", "body": "右腕が、また範囲を広げていた。" },
    { "cmd": "text", "char": "narrator", "body": "痛みはなかった。感覚がなかった。ただ——紋様が、昨日より深く、広く、皮膚の下を走っていた。" },
    { "cmd": "sprite", "char": "kanata", "pose": "arm", "position": "center" },
    { "cmd": "text", "char": "narrator", "body": "廃礼拝堂。ナインフォールの廃区。三度目の神害処理を終えた朝。" },
    { "cmd": "text", "char": "narrator", "body": "誰も来ない場所だ。神の遺骸が降ってくる都市で、遺骸に寄生された者が安全でいられる場所は——どこにもない。" },
    { "cmd": "sprite", "char": "kanata", "pose": "normal", "position": "center" },
    { "cmd": "se", "id": "arm_pulse" },
    { "cmd": "text", "char": "narrator", "body": "右腕が反応した。微かに、だが確かに。" },
    { "cmd": "text", "char": "narrator", "body": "——何かがいる。" },
    { "cmd": "bgm", "id": "abandoned_chapel", "fade": 1.5 },
    { "cmd": "text", "char": "narrator", "body": "礼拝堂の奥。瓦礫の向こう。音もなく——少女が立っていた。" },
    { "cmd": "sprite", "char": "lilith", "pose": "normal", "position": "right" },
    { "cmd": "text", "char": "narrator", "body": "白い肌。首筋に、かすかな影——侵蝕の始まりに見えた。" },
    { "cmd": "text", "char": "narrator", "body": "少女は動かなかった。カナタを見ていなかった。何かを——聴いていた。" },
    { "cmd": "text", "char": "kanata", "body": "……。" },
    { "cmd": "text", "char": "narrator", "body": "カナタは少女を見た。少女はカナタを見ていなかった。" },
    { "cmd": "text", "char": "kanata", "body": "ウタが聴こえるのか。" },
    { "cmd": "sprite", "char": "lilith", "pose": "surprised", "position": "right" },
    { "cmd": "text", "char": "lilith", "body": "——っ。" },
    { "cmd": "text", "char": "narrator", "body": "少女が振り返った。耳が赤かった。" },
    { "cmd": "text", "char": "lilith", "body": "……あなたは、神憑き。" },
    { "cmd": "text", "char": "kanata", "body": "そうだ。" },
    { "cmd": "text", "char": "lilith", "body": "なんで——聴こえないの。あなたには。なんで引かれないの。" },
    { "cmd": "text", "char": "kanata", "body": "……わからない。" },
    { "cmd": "flag", "key": "MET_LILITH", "value": "true" },
    { "cmd": "text", "char": "narrator", "body": "そのとき——礼拝堂の扉が砕けた。" },
    { "cmd": "bgm", "id": "pursuit", "fade": 0.3 },
    { "cmd": "effect", "type": "shake", "intensity": 0.6, "duration": 0.8 },
    { "cmd": "se", "id": "glass_break" },
    { "cmd": "sprite", "char": "kanata", "pose": "normal", "position": "left" },
    { "cmd": "text", "char": "narrator", "body": "マヨイだった。かつて人間だったもの。ウタに引かれ、形を失ったもの。" },
    { "cmd": "text", "char": "narrator", "body": "それが——三体。扉を超えて、礼拝堂に流れ込んできた。" },
    { "cmd": "effect", "type": "shake", "intensity": 0.4, "duration": 0.5 },
    { "cmd": "text", "char": "kanata", "body": "下がれ。" },
    { "cmd": "text", "char": "lilith", "body": "……。" },
    { "cmd": "text", "char": "narrator", "body": "少女は下がらなかった。動けなかったのかもしれない。あるいは——諦めていたのかもしれない。" },
    { "cmd": "se", "id": "arm_pulse" },
    { "cmd": "effect", "type": "flash", "color": "white", "duration": 0.2 },
    { "cmd": "text", "char": "narrator", "body": "右腕が応えた。熱ではなく、光でもなく——ただ、確かな力として。" },
    { "cmd": "effect", "type": "shake", "intensity": 0.8, "duration": 1.2 },
    { "cmd": "text", "char": "narrator", "body": "戦闘は、長くなかった。" },
    { "cmd": "effect", "type": "shake", "intensity": 0.5, "duration": 0.6 },
    { "cmd": "bgm", "id": "abandoned_chapel", "fade": 2.0 },
    { "cmd": "text", "char": "narrator", "body": "三体のマヨイが消えた。礼拝堂に、静寂が戻った。" },
    { "cmd": "sprite", "char": "kanata", "pose": "arm", "position": "left" },
    { "cmd": "text", "char": "narrator", "body": "カナタは右腕を見た。紋様が、また広がっていた。肩の手前まで。" },
    { "cmd": "sprite", "char": "lilith", "pose": "normal", "position": "right" },
    { "cmd": "text", "char": "lilith", "body": "……ありがとう。" },
    { "cmd": "text", "char": "kanata", "body": "……。" },
    { "cmd": "text", "char": "narrator", "body": "カナタは答えなかった。" },
    { "cmd": "text", "char": "lilith", "body": "名前、聞いてもいい？" },
    { "cmd": "text", "char": "kanata", "body": "……カナタ。" },
    { "cmd": "text", "char": "lilith", "body": "リリス。——また、会うかもしれない。" },
    { "cmd": "text", "char": "narrator", "body": "少女は音もなく、廃礼拝堂を出ていった。" },
    { "cmd": "sprite", "char": "lilith", "pose": "hide" },
    { "cmd": "text", "char": "narrator", "body": "カナタはしばらく、扉の向こうを見ていた。" },
    { "cmd": "bgm", "id": "nainfall_ambient", "fade": 3.0 },
    { "cmd": "effect", "type": "fade", "intensity": 1.0, "duration": 2.0 },
    { "cmd": "flag", "key": "CHAPTER01_COMPLETE", "value": "true" }
  ]
}
