{
  "chapterId": "chapter09",
  "title": "第9話「荒野の夜」",
  "commands": [
    { "cmd": "bgm", "id": "nainfall_ambient", "fade": 3.0 },
    { "cmd": "bg", "id": "open_plain", "transition": "fade" },
    { "cmd": "text", "char": "narrator", "body": "ナインフォールの外。荒野に、夜が来ていた。" },
    { "cmd": "text", "char": "narrator", "body": "神の遺骸が降る都市は、遠く後ろに光っていた。" },
    { "cmd": "sprite", "char": "kanata", "pose": "normal", "position": "left" },
    { "cmd": "sprite", "char": "lilith", "pose": "normal", "position": "right" },
    { "cmd": "text", "char": "narrator", "body": "二人は並んで歩いていた。" },
    { "cmd": "text", "char": "lilith", "body": "ウタが……聴こえなくなりました。" },
    { "cmd": "text", "char": "kanata", "body": "……核が侵蝕を消した。声を引き寄せる素地も、一緒に。" },
    { "cmd": "text", "char": "lilith", "body": "静かです。こんなに静かなのは、何年ぶりだろう。" },
    { "cmd": "text", "char": "narrator", "body": "荒野の風が二人の間を抜けていった。" },
    { "cmd": "text", "char": "lilith", "body": "あなたは——ウタが弾けなくなった。ウタが聴こえる場所に行けば、マヨイになるかもしれない。" },
    { "cmd": "text", "char": "kanata", "body": "……そうかもしれない。" },
    { "cmd": "text", "char": "lilith", "body": "怖くないんですか。" },
    { "cmd": "text", "char": "kanata", "body": "……考えていない。" },
    { "cmd": "text", "char": "narrator", "body": "それは嘘ではなかった。考えていなかった、というよりも——考える前に動いていた。" },
    { "cmd": "se", "id": "steam_pipe" },
    { "cmd": "text", "char": "lilith", "body": "カナタさん。" },
    { "cmd": "text", "char": "kanata", "body": "……なんだ。" },
    { "cmd": "text", "char": "lilith", "body": "また戻ってこれますか。ナインフォールに。" },
    { "cmd": "text", "char": "narrator", "body": "カナタは少し間を置いた。" },
    { "cmd": "text", "char": "kanata", "body": "……分からない。" },
    { "cmd": "sprite", "char": "lilith", "pose": "surprised", "position": "right" },
    { "cmd": "text", "char": "lilith", "body": "分からない、って言ったんですか。あなたが。" },
    { "cmd": "text", "char": "kanata", "body": "……言ったが。" },
    { "cmd": "text", "char": "lilith", "body": "初めて聞いた気がします、そういう言葉。" },
    { "cmd": "text", "char": "narrator", "body": "静かな夜だった。神害もなく、ウタもなく、ただ荒野の風だけが吹いていた。" },
    { "cmd": "text", "char": "lilith", "body": "……私も分からないけど。" },
    { "cmd": "text", "char": "lilith", "body": "あなたと一緒に歩くなら、分からなくても、まあいいかなと思います。" },
    { "cmd": "text", "char": "kanata", "body": "……そうか。" },
    { "cmd": "text", "char": "narrator", "body": "カナタは短くそれだけ言った。" },
    { "cmd": "text", "char": "narrator", "body": "二人は歩き続けた。行き先はまだ決まっていなかった。" },
    { "cmd": "text", "char": "narrator", "body": "やがて夜明けの光が荒野の端から差し込んだ。神の遺骸が降る都市が、遠く金色に輝いていた。" },
    { "cmd": "bgm", "id": "nainfall_ambient", "fade": 5.0 },
    { "cmd": "effect", "type": "fade", "duration": 2.0 },
    { "cmd": "flag", "key": "CHAPTER09_COMPLETE", "value": "true" },
    { "cmd": "flag", "key": "ENDING_NORMAL", "value": "true" }
  ]
}
