    { "cmd": "text", "char": "kanata", "body": "……なぜここが分かった。" },
    { "cmd": "text", "char": "lilith", "body": "ウタが教えてくれました。あなたの気配を追ってきたら、ここに。" },
    { "cmd": "text", "char": "kanata", "body": "それは好都合じゃない。" },
    { "cmd": "text", "char": "lilith", "body": "追い払うつもりですか。" },
    { "cmd": "text", "char": "kanata", "body": "……帰れ。" },
    { "cmd": "text", "char": "lilith", "body": "帰りません。" },
    { "cmd": "se", "id": "steam_pipe" },
    { "cmd": "text", "char": "narrator", "body": "リリスが一歩踏み出した。その時、カナタの右腕が微かに反応した。" },
    { "cmd": "se", "id": "arm_pulse" },
    { "cmd": "text", "char": "narrator", "body": "——首筋。" },
    { "cmd": "text", "char": "narrator", "body": "白い肌の、耳の後ろ。そこに走る、細い影のような線。侵蝕の痕だ。" },
    { "cmd": "sprite", "char": "kanata", "pose": "serious", "position": "left" },
    { "cmd": "text", "char": "kanata", "body": "……止まれ。" },
    { "cmd": "sprite", "char": "lilith", "pose": "surprised", "position": "center" },
    { "cmd": "text", "char": "lilith", "body": "え？" },
    { "cmd": "text", "char": "kanata", "body": "首を見せろ。" },
    { "cmd": "text", "char": "lilith", "body": "……？" },
    { "cmd": "text", "char": "narrator", "body": "リリスが髪をかき上げた。首筋に走る痕が、朝の光の中でくっきりと浮かぶ。" },
    { "cmd": "effect", "type": "flash", "color": "white", "duration": 0.3 },
    { "cmd": "text", "char": "kanata", "body": "侵蝕が始まっている。" },
    { "cmd": "text", "char": "lilith", "body": "知っています。ウタを聴き続けると、そうなるって。" },
    { "cmd": "text", "char": "kanata", "body": "いつからだ。" },
    { "cmd": "text", "char": "lilith", "body": "……三日前、くらいです。最初は小さな点でした。" },
    { "cmd": "text", "char": "kanata", "body": "七日。放置すればそこまでだ。" },
    { "cmd": "sprite", "char": "lilith", "pose": "sad", "position": "center" },
    { "cmd": "text", "char": "lilith", "body": "七日で、マヨイになるということ？" },
    { "cmd": "text", "char": "kanata", "body": "……ああ。" },
    { "cmd": "text", "char": "lilith", "body": "やっぱり、そうでしたか。" },
    { "cmd": "text", "char": "narrator", "body": "リリスは表情を変えなかった。恐怖でも絶望でもない、どこか納得したような顔をしていた。" },
    { "cmd": "text", "char": "kanata", "body": "……なぜ平然としている。" },
    { "cmd": "text", "char": "lilith", "body": "死ぬことは怖くないんです。ずっと前から分かっていたことだから。" },
    { "cmd": "text", "char": "narrator", "body": "カナタは少し黙った。" },
    { "cmd": "bgm", "id": "ruins_echo", "fade": 1.5 },
    { "cmd": "bg", "id": "market_district", "transition": "fade" },
    { "cmd": "text", "char": "narrator", "body": "結果として、二人は市場を歩いていた。理由はカナタにも説明しにくかった。" },
    { "cmd": "text", "char": "lilith", "body": "ウタのことを、もっと聞かせてもらえますか。" },
    { "cmd": "text", "char": "kanata", "body": "なぜ聞きたい。" },
    { "cmd": "text", "char": "lilith", "body": "ウタが聴こえ始めたのは、去年のことです。最初は夢の中だけでした。でも今は、起きていても聴こえる。" },
    { "cmd": "text", "char": "lilith", "body": "何かを呼んでいる声なのに、その呼ばれている何かが分からない。" },
    { "cmd": "text", "char": "kanata", "body": "……それが、ウタだ。死んだ神憑きの残留する意志が、声になる。" },
    { "cmd": "text", "char": "lilith", "body": "死んだ人の声。" },
    { "cmd": "text", "char": "kanata", "body": "正確には、死ぬ時に解放された感情の残滓だ。それが空気中に漂い、受け取れる者に届く。" },
    { "cmd": "text", "char": "lilith", "body": "あなたには届かない。" },
    { "cmd": "text", "char": "kanata", "body": "ああ。右腕がそれを弾く。" },
    { "cmd": "se", "id": "crowd_murmur" },
    { "cmd": "text", "char": "lilith", "body": "……孤独だったんじゃないですか。声が届かないって。" },
    { "cmd": "text", "char": "kanata", "body": "考えたことがない。" },
    { "cmd": "text", "char": "lilith", "body": "そうですか。" },
    { "cmd": "text", "char": "narrator", "body": "市場の雑踏が二人の間を流れていった。" },
    { "cmd": "text", "char": "kanata", "body": "……監視する。それだけだ。勘違いするな。" },
    { "cmd": "text", "char": "lilith", "body": "はい。" },
    { "cmd": "sprite", "char": "lilith", "pose": "smile", "position": "center" },
    { "cmd": "text", "char": "lilith", "body": "ありがとうございます、カナタさん。" },
    { "cmd": "flag", "key": "LILITH_JOINED", "value": "true" },
    { "cmd": "flag", "key": "CHAPTER02_COMPLETE", "value": "true" }
