    { "cmd": "text", "char": "narrator", "body": "翌朝。ナインフォールの裏路地に、蒸気が立ち込めていた。" },
    { "cmd": "text", "char": "narrator", "body": "カナタが廃区の拠点に戻ると、扉の前に人影があった。" },
    { "cmd": "sprite", "char": "lilith", "pose": "normal", "position": "center" },
    { "cmd": "text", "char": "lilith", "body": "おはようございます。" },
