{
  "chapterId": "chapter03",
  "title": "第3話「帝国の騎士」",
  "commands": [
    { "cmd": "bgm", "id": "nainfall_ambient", "fade": 2.0 },
    { "cmd": "bg", "id": "nainfall_street", "transition": "fade" },
    { "cmd": "sprite", "char": "kanata", "pose": "normal", "position": "left" },
    { "cmd": "sprite", "char": "lilith", "pose": "normal", "position": "right" },
    { "cmd": "text", "char": "narrator", "body": "翌日。二人が廃区の外れを歩いていた時、足音が止まった。" },
    { "cmd": "se", "id": "footsteps" },
    { "cmd": "text", "char": "kanata", "body": "……止まれ。" },
    { "cmd": "sprite", "char": "lilith", "pose": "surprised", "position": "right" },
    { "cmd": "text", "char": "lilith", "body": "え——" },
    { "cmd": "bgm", "id": "tense_strings", "fade": 0.5 },
    { "cmd": "text", "char": "narrator", "body": "路地の奥から、重い足音が近づいてくる。整然とした、訓練された歩み。" },
    { "cmd": "sprite", "char": "grief", "pose": "normal", "position": "center" },
    { "cmd": "se", "id": "footsteps" },
    { "cmd": "text", "char": "grief", "body": "逃げなくていい。殺しに来たわけじゃない。" },
    { "cmd": "text", "char": "kanata", "body": "……グリーフ。帝国の猟犬が、こんな場所に。" },
    { "cmd": "text", "char": "grief", "body": "任務だ。——神憑き一名と、確保対象一名。" },
    { "cmd": "sprite", "char": "lilith", "pose": "serious", "position": "right" },
    { "cmd": "text", "char": "lilith", "body": "確保対象……私のこと？" },
    { "cmd": "text", "char": "grief", "body": "首筋の侵蝕反応が帝国の観測網に引っかかった。リリス・テスラ。帝国は君を保護したいと言っている。" },
    { "cmd": "text", "char": "kanata", "body": "保護という言葉を、帝国が使う時の意味は知っている。" },
    { "cmd": "text", "char": "grief", "body": "カナタ・イグル。お前とは別の話だ。邪魔をするなら——" },
    { "cmd": "effect", "type": "shake", "intensity": 0.3, "duration": 0.4 },
    { "cmd": "se", "id": "arm_pulse" },
    { "cmd": "text", "char": "narrator", "body": "カナタの右腕が光を帯びた。グリーフの手が剣の柄に触れる。" },
    { "cmd": "text", "char": "narrator", "body": "沈黙が路地を満たした。" },
    { "cmd": "choice", "options": [
      { "label": "リリスを置いて逃げる", "flag": "SAVED_LILITH", "value": "false" },
      { "label": "リリスと共に逃げる", "flag": "SAVED_LILITH", "value": "true" }
    ]},
    { "cmd": "text", "char": "kanata", "body": "行くぞ。" },
    { "cmd": "sprite", "char": "lilith", "pose": "surprised", "position": "right" },
    { "cmd": "text", "char": "lilith", "body": "え——" },
    { "cmd": "text", "char": "kanata", "body": "走れ。" },
    { "cmd": "bgm", "id": "pursuit", "fade": 0.3 },
    { "cmd": "effect", "type": "shake", "intensity": 0.4, "duration": 0.5 },
    { "cmd": "se", "id": "footsteps" },
    { "cmd": "text", "char": "narrator", "body": "二人は路地を駆け抜けた。グリーフが追ってくる気配があった。しかし——" },
    { "cmd": "bg", "id": "underground_passage", "transition": "fade" },
    { "cmd": "bgm", "id": "ruins_echo", "fade": 1.0 },
    { "cmd": "text", "char": "narrator", "body": "地下道に飛び込んで、足音が止んだ。" },
    { "cmd": "sprite", "char": "lilith", "pose": "normal", "position": "right" },
    { "cmd": "sprite", "char": "kanata", "pose": "serious", "position": "left" },
    { "cmd": "text", "char": "lilith", "body": "……追ってこない？" },
    { "cmd": "text", "char": "kanata", "body": "……ああ。" },
    { "cmd": "text", "char": "lilith", "body": "なぜ。" },
    { "cmd": "text", "char": "kanata", "body": "分からない。" },
    { "cmd": "text", "char": "narrator", "body": "地上では、グリーフが路地の前で立ち止まっていた。" },
    { "cmd": "sprite", "char": "grief", "pose": "serious", "position": "center" },
    { "cmd": "sprite", "char": "kanata", "pose": "hide", "position": "left" },
    { "cmd": "sprite", "char": "lilith", "pose": "hide", "position": "right" },
    { "cmd": "text", "char": "grief", "body": "……侵蝕が進んでいた。七日、保たないかもしれない。" },
    { "cmd": "text", "char": "grief", "body": "帝国が「保護」すれば、残り時間はもっと短くなる。" },
    { "cmd": "text", "char": "narrator", "body": "グリーフは剣の柄から手を離した。踵を返し、一人で来た道を戻っていく。" },
    { "cmd": "text", "char": "grief", "body": "……任務、失敗だ。" },
    { "cmd": "flag", "key": "GRIEF_DOUBTS", "value": "true" },
    { "cmd": "flag", "key": "CHAPTER03_COMPLETE", "value": "true" }
  ]
}
