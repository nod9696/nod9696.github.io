{
  "chapterId": "chapter06",
  "title": "第6話「決断と名前」",
  "commands": [
    { "cmd": "bgm", "id": "ruins_echo", "fade": 2.0 },
    { "cmd": "bg", "id": "underground_passage", "transition": "fade" },
    { "cmd": "sprite", "char": "kanata", "pose": "normal", "position": "left" },
    { "cmd": "sprite", "char": "lilith", "pose": "normal", "position": "right" },
    { "cmd": "text", "char": "narrator", "body": "施設への道を歩きながら、リリスが不意に口を開いた。" },
    { "cmd": "text", "char": "lilith", "body": "マヨワズ、というのはどういう意味ですか。" },
    { "cmd": "text", "char": "kanata", "body": "……どこで聞いた。" },
    { "cmd": "text", "char": "lilith", "body": "エレオノーラさんが、そう呼んでいました。あなたの名前とは別に。" },
    { "cmd": "text", "char": "kanata", "body": "忌み名だ。迷わない者、という意味らしい。" },
    { "cmd": "text", "char": "lilith", "body": "迷わない者……。" },
    { "cmd": "text", "char": "kanata", "body": "ウタに惹かれない。マヨイにならない。だから忌み名になる。" },
    { "cmd": "text", "char": "lilith", "body": "なぜ忌み名なんですか。迷わないことは、良いことじゃ——" },
    { "cmd": "text", "char": "kanata", "body": "迷わないということは、声が届かないということだ。人の声も、神の声も。" },
    { "cmd": "text", "char": "narrator", "body": "リリスが少し黙った。" },
    { "cmd": "text", "char": "lilith", "body": "ずっと、一人で戦ってきたんですか。" },
    { "cmd": "text", "char": "kanata", "body": "……そういう話じゃない。" },
    { "cmd": "text", "char": "lilith", "body": "でも、そうですよね。ウタが聴こえない。声が届かない。誰かと分かち合えない。" },
    { "cmd": "sprite", "char": "kanata", "pose": "serious", "position": "left" },
    { "cmd": "text", "char": "kanata", "body": "……昔、一人だけいた。" },
    { "cmd": "text", "char": "lilith", "body": "え？" },
    { "cmd": "text", "char": "kanata", "body": "一緒にいた人間が。ウタが聴こえて、でもマヨイにならなかった。不思議な奴だった。" },
    { "cmd": "text", "char": "kanata", "body": "俺がウタを弾く理由を、それでも信じたいと言っていた。" },
    { "cmd": "text", "char": "lilith", "body": "……今は？" },
    { "cmd": "text", "char": "narrator", "body": "カナタは答えなかった。" },
    { "cmd": "text", "char": "narrator", "body": "答えない、ということが答えだった。" },
    { "cmd": "se", "id": "steam_pipe" },
    { "cmd": "text", "char": "lilith", "body": "マヨワズという名前は、あなたにとって呪いですか。" },
    { "cmd": "text", "char": "kanata", "body": "……知らない。考えたことがなかった。" },
    { "cmd": "text", "char": "lilith", "body": "私は、好きだと思います。" },
    { "cmd": "text", "char": "kanata", "body": "……なぜ。" },
    { "cmd": "text", "char": "lilith", "body": "迷わないから、あなたは私の隣を歩ける。声に引かれない。流されない。" },
    { "cmd": "text", "char": "lilith", "body": "ウタの世界にいる私には、そういう人が必要だと思うから。" },
    { "cmd": "sprite", "char": "kanata", "pose": "normal", "position": "left" },
    { "cmd": "text", "char": "kanata", "body": "……感傷的な話だ。" },
    { "cmd": "text", "char": "lilith", "body": "はい。でも本当のことです。" },
    { "cmd": "text", "char": "narrator", "body": "しばらく二人は無言で歩いた。地下道の蒸気が、足元を流れていく。" },
    { "cmd": "text", "char": "kanata", "body": "……お前は、なぜウタを聴き続ける。" },
    { "cmd": "text", "char": "lilith", "body": "呼ばれているから。" },
    { "cmd": "text", "char": "kanata", "body": "誰に。" },
    { "cmd": "text", "char": "lilith", "body": "分からない。でも、確かに呼ばれている。名前を呼ばれているわけじゃないのに、私だけに届く声がある。" },
    { "cmd": "text", "char": "lilith", "body": "それを無視して生きることが、私にはできないんです。" },
    { "cmd": "text", "char": "narrator", "body": "カナタはそれを聞いて、何かを言いかけて、止めた。" },
    { "cmd": "text", "char": "kanata", "body": "……急ぐぞ。" },
    { "cmd": "text", "char": "lilith", "body": "はい。" },
    { "cmd": "flag", "key": "CHAPTER06_COMPLETE", "value": "true" }
  ]
}
