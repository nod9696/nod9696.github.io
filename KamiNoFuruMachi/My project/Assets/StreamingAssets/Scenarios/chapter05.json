{
  "chapterId": "chapter05",
  "title": "第5話「七日間」",
  "commands": [
    { "cmd": "bgm", "id": "ruins_echo", "fade": 2.0 },
    { "cmd": "bg", "id": "underground_passage", "transition": "fade" },
    { "cmd": "sprite", "char": "kanata", "pose": "normal", "position": "left" },
    { "cmd": "sprite", "char": "lilith", "pose": "normal", "position": "right" },
    { "cmd": "text", "char": "narrator", "body": "地下道の先、石造りの小部屋に灯りがあった。" },
    { "cmd": "se", "id": "door_open" },
    { "cmd": "sprite", "char": "eleonora", "pose": "normal", "position": "center" },
    { "cmd": "text", "char": "eleonora", "body": "来ると思っていたわ。追われている神憑きがここを使うことは、よく知っている。" },
    { "cmd": "text", "char": "kanata", "body": "……エレオノーラ。帝国の科学者が、なぜここに。" },
    { "cmd": "text", "char": "eleonora", "body": "今日は帝国の人間じゃない。" },
    { "cmd": "text", "char": "narrator", "body": "エレオノーラの上着の徽章が、裏返しにつけられていた。" },
    { "cmd": "text", "char": "eleonora", "body": "その子を診せて。首筋の侵蝕、グリーフの報告で知った。" },
    { "cmd": "sprite", "char": "lilith", "pose": "surprised", "position": "right" },
    { "cmd": "text", "char": "lilith", "body": "診る……？" },
    { "cmd": "text", "char": "kanata", "body": "信用できる理由がない。" },
    { "cmd": "text", "char": "eleonora", "body": "ないわね。でも私以外に、侵蝕の進行速度を計算できる人間はいない。" },
    { "cmd": "text", "char": "narrator", "body": "沈黙。カナタが視線でリリスに問う。リリスが小さく頷いた。" },
    { "cmd": "se", "id": "steam_pipe" },
    { "cmd": "text", "char": "narrator", "body": "エレオノーラが丁寧にリリスの首筋を診察した。機器を使い、光を当て、数値を記録していく。" },
    { "cmd": "text", "char": "eleonora", "body": "……思ったより進んでいる。" },
    { "cmd": "text", "char": "kanata", "body": "七日と言った。" },
    { "cmd": "text", "char": "eleonora", "body": "七日は楽観的な数字ね。実際は——四日、かもしれない。" },
    { "cmd": "effect", "type": "shake", "intensity": 0.2, "duration": 0.4 },
    { "cmd": "sprite", "char": "lilith", "pose": "sad", "position": "right" },
    { "cmd": "text", "char": "lilith", "body": "四日。" },
    { "cmd": "text", "char": "eleonora", "body": "止める方法はある。ただし——遺骸の核が必要だ。" },
    { "cmd": "text", "char": "kanata", "body": "核。" },
    { "cmd": "text", "char": "eleonora", "body": "帝国の第三管理施設の地下に保管されている、原初の遺骸の欠片よ。侵蝕を逆流させるのに使える。" },
    { "cmd": "text", "char": "kanata", "body": "……帝国の施設の中枢に、どうやって入る。" },
    { "cmd": "text", "char": "eleonora", "body": "私が案内できる。ただし一つ——" },
    { "cmd": "text", "char": "eleonora", "body": "核を使うことには、代償がある。それは施設に入ってから話す。" },
    { "cmd": "text", "char": "kanata", "body": "……信用できない条件だ。" },
    { "cmd": "text", "char": "eleonora", "body": "ええ。でも四日後に選択肢はなくなる。" },
    { "cmd": "text", "char": "narrator", "body": "リリスが静かに口を開いた。" },
    { "cmd": "text", "char": "lilith", "body": "死んでもいい、という気持ちはあります。でも——" },
    { "cmd": "text", "char": "lilith", "body": "マヨイになるのは、嫌です。自分じゃない何かになる前に、ちゃんと終わりたい。" },
    { "cmd": "sprite", "char": "kanata", "pose": "serious", "position": "left" },
    { "cmd": "text", "char": "kanata", "body": "黙れ。" },
    { "cmd": "sprite", "char": "lilith", "pose": "surprised", "position": "right" },
    { "cmd": "text", "char": "lilith", "body": "カナタさん？" },
    { "cmd": "text", "char": "kanata", "body": "……軽々しく言うな。そういうことを。" },
    { "cmd": "text", "char": "narrator", "body": "低い声だった。怒りとも、別の何かとも、判断がつかない声だった。" },
    { "cmd": "text", "char": "eleonora", "body": "……。" },
    { "cmd": "choice", "options": [
      { "label": "「施設へ行く」", "flag": "LILITH_FOLLOWS_WILLINGLY", "value": "true" },
      { "label": "「なぜ助けようとする」とエレオノーラに問う", "flag": "LILITH_ASKS_WHY", "value": "true" }
    ]},
    { "cmd": "text", "char": "kanata", "body": "案内しろ。施設へ行く。" },
    { "cmd": "text", "char": "eleonora", "body": "……ええ。分かった。" },
    { "cmd": "sprite", "char": "eleonora", "pose": "hide", "position": "center" },
    { "cmd": "text", "char": "narrator", "body": "エレオノーラが先に立って歩き始めた。カナタはリリスを一瞥してから、その後に続いた。" },
    { "cmd": "flag", "key": "KANATA_EMOTION_SHOWN", "value": "true" },
    { "cmd": "flag", "key": "CHAPTER05_COMPLETE", "value": "true" }
  ]
}
