{
  "chapterId": "chapter06",
  "title": "第六章「後退の夜」",
  "commands": [
    { "cmd": "bgm", "id": "night_ambient", "fade": 3.0 },
    { "cmd": "bg", "id": "saki_room", "transition": "fade" },
    { "cmd": "text", "char": "narrator", "body": "戻ってきた夜だった。" },
    { "cmd": "text", "char": "narrator", "body": "波のように寄せては引く——サキはそれを知っていた。少し楽になっても、また来る。それが自分の内側にあるものの性質だと、もう知っていた。" },
    { "cmd": "sprite", "char": "saki", "pose": "sad", "position": "left" },
    { "cmd": "text", "char": "saki", "body": "（また来た。この感じ。）" },
    { "cmd": "text", "char": "narrator", "body": "深夜、窓の外を見ていた。街灯の光が路面に溜まって、遠くの車のヘッドライトが通り過ぎていた。" },
    { "cmd": "text", "char": "saki", "body": "（消えたいな、と思う。昨日より少し、強く。）" },
    { "cmd": "text", "char": "saki", "body": "（でもなんで——昨日より強いんだろう。昨日は少し良かったのに。）" },
    { "cmd": "text", "char": "narrator", "body": "それが後退というものだった。前に進んだと思った分、揺り戻しが来る。感情は直線では動かない。" },
    { "cmd": "sprite", "char": "kirie", "pose": "normal", "position": "right" },
    { "cmd": "text", "char": "narrator", "body": "キリエが近づいた。音もなく、気づけば隣に立っていた。" },
    { "cmd": "text", "char": "saki", "body": "……気づいてたよ。最初から。" },
    { "cmd": "text", "char": "kirie", "body": "……そうか。" },
    { "cmd": "text", "char": "narrator", "body": "二人は窓の外を見た。何かを言うわけでもなかった。" },
    { "cmd": "text", "char": "saki", "body": "また来た、例の感じ。" },
    { "cmd": "text", "char": "kirie", "body": "……知っている。" },
    { "cmd": "text", "char": "saki", "body": "わかるの？" },
    { "cmd": "text", "char": "kirie", "body": "空気が変わる。サキが窓に近づくとき——いつも、少し違う。" },
    { "cmd": "text", "char": "saki", "body": "（そんなの、気づいてたんだ。……なんか、恥ずかしいような、安心するような。）" },
    { "cmd": "bgm", "id": "melancholy_theme", "fade": 3.0 },
    { "cmd": "text", "char": "narrator", "body": "キリエはサキの方を見なかった。窓の外を見ていた。でもその視線はサキを意識していた——サキはそれを感じていた。" },
    { "cmd": "text", "char": "saki", "body": "キリエって、私のこと食べようとしたんでしょ。最初のとき。" },
    { "cmd": "text", "char": "kirie", "body": "……。" },
    { "cmd": "text", "char": "saki", "body": "正直に言っていいよ。" },
    { "cmd": "text", "char": "kirie", "body": "……食べようとした。食べなかった。" },
    { "cmd": "text", "char": "saki", "body": "なんで？" },
    { "cmd": "text", "char": "kirie", "body": "……わからなかった。食べなかった、という選択が、あのとき自分にできると知らなかった。" },
    { "cmd": "text", "char": "narrator", "body": "五百万年生きてきたキリエが、初めて「食べない」を選んだ夜。それがサキとの最初の夜だった。" },
    { "cmd": "text", "char": "saki", "body": "……そっか。" },
    { "cmd": "text", "char": "saki", "body": "それって、たぶん——私が嫌いじゃなかったってこと？" },
    { "cmd": "text", "char": "kirie", "body": "……八割くらいは、ここにいてほしいから。" },
    { "cmd": "text", "char": "saki", "body": "……え。" },
    { "cmd": "text", "char": "narrator", "body": "サキは少し固まった。" },
    { "cmd": "text", "char": "saki", "body": "八割って、残り二割は？" },
    { "cmd": "text", "char": "kirie", "body": "……まだわからない。" },
    { "cmd": "text", "char": "saki", "body": "（……なんか、ずるい言い方だな。でも、嘘じゃないんだろうな。）" },
    { "cmd": "text", "char": "narrator", "body": "窓の外で車が一台、遠ざかっていった。街灯の下を猫が横切った。世界は動いていた。" },
    { "cmd": "choice", "options": [
      { "label": "「ありがとう」と言う", "flag": "SAKI_THANKS", "value": "true" },
      { "label": "「八割って少なくない？」とつっこむ", "flag": "SAKI_TSUKKOMI", "value": "true" }
    ]},
    { "cmd": "text", "char": "saki", "body": "……ねえ、キリエ。" },
    { "cmd": "text", "char": "kirie", "body": "何。" },
    { "cmd": "text", "char": "saki", "body": "今夜、隣にいて。" },
    { "cmd": "sprite", "char": "kirie", "pose": "normal", "position": "right" },
    { "cmd": "text", "char": "narrator", "body": "キリエは少しだけ、サキの方に体を向けた。" },
    { "cmd": "text", "char": "kirie", "body": "……いる。" },
    { "cmd": "flag", "key": "KIRIE_CHOSE_STAY", "value": "true" },
    { "cmd": "text", "char": "narrator", "body": "二人は並んで夜を見た。何も解決していなかった。波は来ていた。でも今夜は——一人じゃなかった。" },
    { "cmd": "text", "char": "narrator", "body": "それだけで、少しだけ、窓の外が遠くなった。" }
  ]
}
