{
  "chapterId": "chapter09",
  "title": "街の昼間",
  "commands": [
    { "cmd": "bgm", "id": "city_ambient", "fade": 2.0 },
    { "cmd": "bg", "id": "cafe_interior", "transition": "fade" },
    { "cmd": "text", "char": "narrator", "body": "午後の光がカフェの窓から差し込んでいた。砂糖の匂いと、誰かの笑い声と——そういうもので満ちた場所に、三人はいた。" },
    { "cmd": "sprite", "char": "suzumura", "pose": "smile", "position": "right" },
    { "cmd": "sprite", "char": "saki", "pose": "normal", "position": "center" },
    { "cmd": "sprite", "char": "kirie", "pose": "serious", "position": "left" },
    { "cmd": "se", "id": "cafe_sounds" },
    { "cmd": "text", "char": "suzumura", "body": "いやー久しぶり！　サキと会えると思ってなかったよ〜。ていかこの子が例の——" },
    { "cmd": "text", "char": "saki", "body": "キリエ。えっと、遠い親戚みたいな感じで、うちに来てる。" },
    { "cmd": "text", "char": "suzumura", "body": "親戚！　めっちゃ雰囲気ちがくない？　美人すぎない？" },
    { "cmd": "sprite", "char": "kirie", "pose": "normal", "position": "left" },
    { "cmd": "text", "char": "kirie", "body": "……見られている。" },
    { "cmd": "text", "char": "suzumura", "body": "あ、ごめんごめん！　見すぎた。えーと、鈴村です。よろしくね！" },
    { "cmd": "text", "char": "kirie", "body": "……逆真キリエ。" },
    { "cmd": "text", "char": "suzumura", "body": "逆真キリエ！　かっこい〜名前。ねえねえ何が好き？　好きな食べ物とか。" },
    { "cmd": "text", "char": "kirie", "body": "……。" },
    { "cmd": "text", "char": "narrator", "body": "ウェイターがケーキを運んできた。チーズケーキ、三つ。キリエはしばらく皿を見ていた。それから、指でそっと表面に触れた。" },
    { "cmd": "text", "char": "suzumura", "body": "ちょ、食べていいよ！？" },
    { "cmd": "text", "char": "kirie", "body": "……乳脂肪と砂糖の凝固体。表面の焼き色は糖化反応。内部は水分を多く含む——弾性がある。" },
    { "cmd": "text", "char": "saki", "body": "分析しないで食べて。" },
    { "cmd": "text", "char": "narrator", "body": "キリエはフォークを持った。少し考えた。口に入れた。" },
    { "cmd": "sprite", "char": "kirie", "pose": "surprised", "position": "left" },
    { "cmd": "text", "char": "kirie", "body": "……。" },
    { "cmd": "text", "char": "saki", "body": "好きなんだ。" },
    { "cmd": "text", "char": "kirie", "body": "……断言するな。" },
    { "cmd": "text", "char": "suzumura", "body": "顔に出てるよ！　無表情のまま三回も食べた！" },
    { "cmd": "text", "char": "saki", "body": "（……キリエがチーズケーキ好き。謎すぎる）" },
    { "cmd": "sprite", "char": "suzumura", "pose": "smile", "position": "right" },
    { "cmd": "text", "char": "suzumura", "body": "ねえ三人で写真撮ろうよ！　記念！" },
    { "cmd": "text", "char": "saki", "body": "えっ——" },
    { "cmd": "text", "char": "suzumura", "body": "ほら〜いくよ〜！" },
    { "cmd": "se", "id": "cafe_sounds" },
    { "cmd": "text", "char": "narrator", "body": "シャッター音。一枚。それから鈴村の顔が変わった。" },
    { "cmd": "sprite", "char": "suzumura", "pose": "surprised", "position": "right" },
    { "cmd": "text", "char": "suzumura", "body": "えっ……ちょっと待って。キリエちゃんだけ、なんか、すごくない？　光の反射が——え、どうやったらこんなに綺麗に映るの？" },
    { "cmd": "text", "char": "saki", "body": "（そりゃそうだよ。なんせこの子、世界最初の……)" },
    { "cmd": "text", "char": "kirie", "body": "……。" },
    { "cmd": "text", "char": "narrator", "body": "鈴村がサキのほうを向いた。口が動いた——声は出ていない。口パクで、「何なのあの子」。サキも口パクで返す。「わかんない」。" },
    { "cmd": "sprite", "char": "kirie", "pose": "normal", "position": "left" },
    { "cmd": "text", "char": "kirie", "body": "……読める。" },
    { "cmd": "text", "char": "suzumura", "body": "えっ！？ 読んだ！？" },
    { "cmd": "text", "char": "saki", "body": "読んだ！" },
    { "cmd": "text", "char": "suzumura", "body": "ごめんねキリエちゃん。謎めいた美少女だなあって思って……" },
    { "cmd": "text", "char": "kirie", "body": "謎ではない。余計なことを言わないだけだ。" },
    { "cmd": "text", "char": "suzumura", "body": "……それはもしかして怒ってる？" },
    { "cmd": "text", "char": "kirie", "body": "怒っていない。ただの説明だ。" },
    { "cmd": "text", "char": "narrator", "body": "鈴村は三秒黙った。それから爆発するように笑った。「やばい、好きかも！」" },
    { "cmd": "bgm", "id": "morning_ambient", "fade": 3.0 },
    { "cmd": "bg", "id": "night_city", "transition": "crossfade" },
    { "cmd": "text", "char": "narrator", "body": "帰り道、夕暮れが街を橙色に染めていた。鈴村は先に別れた。二人だけになった。" },
    { "cmd": "sprite", "char": "saki", "pose": "normal", "position": "center" },
    { "cmd": "sprite", "char": "kirie", "pose": "serious", "position": "left" },
    { "cmd": "text", "char": "saki", "body": "……怖くなかった。" },
    { "cmd": "text", "char": "kirie", "body": "何が。" },
    { "cmd": "text", "char": "saki", "body": "人と話すの。今日。なんか、久しぶりに、怖くなかった。" },
    { "cmd": "text", "char": "kirie", "body": "……。" },
    { "cmd": "text", "char": "narrator", "body": "キリエは何も言わなかった。ただ、少し歩調を緩めた——それだけだった。" }
  ]
}
