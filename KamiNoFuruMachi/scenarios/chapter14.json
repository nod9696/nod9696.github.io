{
  "chapterId": "chapter14",
  "title": "砂糖なしの朝に",
  "commands": [
    { "cmd": "bgm", "id": "morning_ambient", "fade": 3.0 },
    { "cmd": "bg", "id": "saki_room_morning", "transition": "fade" },
    { "cmd": "text", "char": "narrator", "body": "終章から七日後の朝。コーヒーの匂いがした。" },
    { "cmd": "sprite", "char": "saki", "pose": "normal", "position": "center" },
    { "cmd": "text", "char": "narrator", "body": "入江サキはマグカップを両手で持った。砂糖一杯。——以前は三杯だった。少しずつ変わっている。自分でも気づかないうちに。" },
    { "cmd": "sprite", "char": "kirie", "pose": "normal", "position": "left" },
    { "cmd": "text", "char": "narrator", "body": "キリエはテーブルの向かいに座り、分厚い本を持っていた。逆さまに。" },
    { "cmd": "text", "char": "saki", "body": "それ逆さ。" },
    { "cmd": "text", "char": "kirie", "body": "……知っている。こちら向きの方が文字の形が面白い。" },
    { "cmd": "text", "char": "saki", "body": "読めてないじゃん。" },
    { "cmd": "text", "char": "kirie", "body": "文字を読んでいるとは言っていない。形を見ている。" },
    { "cmd": "text", "char": "saki", "body": "（……なんで私はこれに慣れているんだろう）" },
    { "cmd": "text", "char": "saki", "body": "コンビニ行くけど来る？" },
    { "cmd": "text", "char": "kirie", "body": "行く。" },
    { "cmd": "bg", "id": "open_field", "transition": "crossfade" },
    { "cmd": "text", "char": "narrator", "body": "外は秋の終わりの朝だった。空気が少し冷たくて、光だけが温かかった。" },
    { "cmd": "sprite", "char": "kirie", "pose": "serious", "position": "left" },
    { "cmd": "sprite", "char": "saki", "pose": "normal", "position": "right" },
    { "cmd": "text", "char": "narrator", "body": "コンビニの自動ドアが開いた。キリエが少し立ち止まった。" },
    { "cmd": "text", "char": "saki", "body": "入って大丈夫。センサーで開くやつだから。" },
    { "cmd": "text", "char": "kirie", "body": "……勝手に開く扉を、人間は信用するのか。" },
    { "cmd": "text", "char": "saki", "body": "信用してる。毎日使ってる。" },
    { "cmd": "text", "char": "kirie", "body": "……。" },
    { "cmd": "text", "char": "narrator", "body": "キリエは一歩入った。ドアが閉まった。次の客が来るまで、また開かなかった。キリエはそれを確認した。" },
    { "cmd": "text", "char": "kirie", "body": "……なるほど。ドアが、私を認識した。" },
    { "cmd": "text", "char": "saki", "body": "存在を認識されて感動しないで。" },
    { "cmd": "text", "char": "narrator", "body": "ガムのコーナーの前で、キリエが止まった。" },
    { "cmd": "text", "char": "kirie", "body": "……。" },
    { "cmd": "text", "char": "saki", "body": "どれにするか決められない？" },
    { "cmd": "text", "char": "kirie", "body": "種類が多い。選ぶ基準が分からない。" },
    { "cmd": "text", "char": "saki", "body": "じゃあこれ。" },
    { "cmd": "text", "char": "narrator", "body": "サキはミントガムを手に取って、キリエに渡した。キリエはしばらく眺めた。" },
    { "cmd": "text", "char": "kirie", "body": "……ミント。清涼感の類か。" },
    { "cmd": "text", "char": "saki", "body": "噛めば分かるよ。" },
    { "cmd": "bg", "id": "open_field", "transition": "fade" },
    { "cmd": "text", "char": "narrator", "body": "公園のベンチ。紅茶の缶を開ける音がした。午前の光が木の葉を透かしていた。" },
    { "cmd": "sprite", "char": "saki", "pose": "normal", "position": "right" },
    { "cmd": "sprite", "char": "kirie", "pose": "normal", "position": "left" },
    { "cmd": "text", "char": "saki", "body": "いつまでいるの。" },
    { "cmd": "text", "char": "kirie", "body": "決めていない。" },
    { "cmd": "text", "char": "saki", "body": "決める必要ないの？" },
    { "cmd": "text", "char": "kirie", "body": "決める必要があるか。" },
    { "cmd": "text", "char": "saki", "body": "……ないか。" },
    { "cmd": "text", "char": "narrator", "body": "しばらく、二人は何も言わなかった。それで十分だった。" },
    { "cmd": "text", "char": "saki", "body": "砂糖なしのコーヒー、いつになったら飲めるかな。" },
    { "cmd": "text", "char": "kirie", "body": "習慣は繰り返しで変わる。" },
    { "cmd": "text", "char": "saki", "body": "哲学じゃなくて実体験で言ってる？" },
    { "cmd": "text", "char": "kirie", "body": "……五百万の夜で、習慣が変わったことが何度かある。" },
    { "cmd": "text", "char": "saki", "body": "なんか壮大な実体験だ。" },
    { "cmd": "se", "id": "footsteps" },
    { "cmd": "text", "char": "narrator", "body": "十二月五日。サキの誕生日。夜、玄関に白い花束があった。" },
    { "cmd": "sprite", "char": "saki", "pose": "surprised", "position": "center" },
    { "cmd": "text", "char": "saki", "body": "えっ——これは？" },
    { "cmd": "sprite", "char": "kirie", "pose": "normal", "position": "left" },
    { "cmd": "text", "char": "kirie", "body": "……コンビニの店員に聞いた。誕生日には花を渡すものだと。" },
    { "cmd": "text", "char": "saki", "body": "コンビニの店員に——" },
    { "cmd": "text", "char": "kirie", "body": "詳しかった。熱心に教えてくれた。花の種類と、色の意味と、渡し方まで。" },
    { "cmd": "text", "char": "saki", "body": "……どんな店員だったの。" },
    { "cmd": "text", "char": "kirie", "body": "詳しかった。それだけだ。" },
    { "cmd": "text", "char": "saki", "body": "ありがとう、キリエ。" },
    { "cmd": "sprite", "char": "kirie", "pose": "normal", "position": "left" },
    { "cmd": "text", "char": "kirie", "body": "……当分、一年ごとに来る。" },
    { "cmd": "text", "char": "saki", "body": "一年ごとに——って、来年も来るってこと？" },
    { "cmd": "text", "char": "kirie", "body": "花を持って。" },
    { "cmd": "text", "char": "saki", "body": "（……一年後に来ることが既に決まった。それって、一年間いなくなるってことでもあるけど——でも来ることが決まった。それは十分すぎる約束だ）" },
    { "cmd": "text", "char": "saki", "body": "……うん。来て。" },
    { "cmd": "bgm", "id": "epilogue_theme", "fade": 2.0 },
    { "cmd": "text", "char": "narrator", "body": "逆しまに月が落ちていく、という言葉から始まったこの話は——砂糖なしの朝に向かっている。" },
    { "cmd": "text", "char": "narrator", "body": "まだそこには届いていない。砂糖は一杯、まだある。" },
    { "cmd": "text", "char": "narrator", "body": "でも、減っている。少しずつ、確かに、減っている。" },
    { "cmd": "effect", "type": "fade", "intensity": 1.0, "duration": 4.0, "color": "white" },
    { "cmd": "flag", "key": "FLAG_ENDING_NORMAL", "value": "true" }
  ]
}
