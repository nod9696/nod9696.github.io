{
  "chapterId": "chapter07",
  "title": "第七章「川の名前」",
  "commands": [
    { "cmd": "bgm", "id": "night_ambient", "fade": 2.0 },
    { "cmd": "bg", "id": "river_bank", "transition": "fade" },
    { "cmd": "text", "char": "narrator", "body": "川があった。街の端を流れる、名前のある川だった。サキはここが好きだった——理由は言語化したことがなかった。ただ来ると、少し息ができた。" },
    { "cmd": "sprite", "char": "saki", "pose": "normal", "position": "left" },
    { "cmd": "sprite", "char": "kirie", "pose": "normal", "position": "right" },
    { "cmd": "text", "char": "narrator", "body": "二人は川沿いの柵に寄りかかっていた。水面が街灯の光を細かく砕いて、流れていた。" },
    { "cmd": "text", "char": "saki", "body": "ねえ、キリエってどこから来たの。" },
    { "cmd": "text", "char": "kirie", "body": "……どこから。" },
    { "cmd": "text", "char": "saki", "body": "出身地的な意味で。生まれた場所とか、ないの。" },
    { "cmd": "sprite", "char": "kirie", "pose": "serious", "position": "right" },
    { "cmd": "text", "char": "kirie", "body": "……場所ではない。" },
    { "cmd": "text", "char": "saki", "body": "じゃあ、何から来たの。" },
    { "cmd": "text", "char": "narrator", "body": "キリエは川を見た。水が流れていた。止まらなかった。" },
    { "cmd": "text", "char": "kirie", "body": "世界に最初に「死にたい」と泣いた人間がいた。" },
    { "cmd": "text", "char": "saki", "body": "……うん。" },
    { "cmd": "text", "char": "kirie", "body": "その感情が——形を持った。それが私だ。" },
    { "cmd": "text", "char": "saki", "body": "（感情が、形を持った。）" },
    { "cmd": "text", "char": "saki", "body": "じゃあキリエって、死にたいっていう気持ちそのもの？" },
    { "cmd": "text", "char": "kirie", "body": "……近い。ただ、その気持ちが最初に世界に存在した瞬間に、私は生まれた。だから私は——その気持ちより古い。" },
    { "cmd": "text", "char": "saki", "body": "気持ちより古いって……どういうこと。" },
    { "cmd": "text", "char": "kirie", "body": "気持ちを知る前から、気持ちを待っていた、ということかもしれない。" },
    { "cmd": "text", "char": "saki", "body": "（それって、すごく寂しい話だな。）" },
    { "cmd": "bgm", "id": "melancholy_theme", "fade": 3.0 },
    { "cmd": "text", "char": "saki", "body": "逆真って名前、どういう意味なの。" },
    { "cmd": "sprite", "char": "kirie", "pose": "normal", "position": "right" },
    { "cmd": "text", "char": "kirie", "body": "逆さの真実。" },
    { "cmd": "text", "char": "saki", "body": "逆さの真実？" },
    { "cmd": "text", "char": "kirie", "body": "死にたいという気持ちは——逆さから見た、生きたいという気持ちだ。そう言った人間がいた。私に名前をくれた人間が。" },
    { "cmd": "text", "char": "saki", "body": "（名前をくれた人。……昔の、誰か。）" },
    { "cmd": "text", "char": "saki", "body": "なんで五百万年生きてるのに死ねないの。" },
    { "cmd": "text", "char": "kirie", "body": "……死にたいという気持ちが世界から消えれば、私も消える。でも消えたことがない。" },
    { "cmd": "text", "char": "saki", "body": "……それって。" },
    { "cmd": "text", "char": "kirie", "body": "そういうことだ。" },
    { "cmd": "text", "char": "narrator", "body": "川は流れ続けていた。二人はしばらく何も言わなかった。" },
    { "cmd": "effect", "type": "fade", "intensity": 0.6, "duration": 2.0, "color": "white" },
    { "cmd": "bgm", "id": "kirie_hunt", "fade": 3.0 },
    { "cmd": "bg", "id": "night_city", "transition": "crossfade" },
    { "cmd": "text", "char": "narrator", "body": "——記憶は古い順に色あせない。それがキリエの、唯一の呪いだった。" },
    { "cmd": "text", "char": "narrator", "body": "江戸の冬。雪が降っていた。橋の上に少女がいた。" },
    { "cmd": "text", "char": "narrator", "body": "十七か、十八か。着物の裾が雪に濡れていた。欄干を握る手が白かった——寒さではなく、力を込めているせいで。" },
    { "cmd": "text", "char": "narrator", "body": "キリエはそこにいた。食べようとして——止まった。" },
    { "cmd": "text", "char": "narrator", "body": "初めて、止まった夜だった。" },
    { "cmd": "text", "char": "narrator", "body": "少女は欄干から手を離さなかった。でも川に落ちなかった。雪が降り続けた。キリエは少女の横に立って——何もしなかった。ただ、いた。" },
    { "cmd": "text", "char": "narrator", "body": "夜明けが来た。少女は橋から離れた。振り返らなかった。" },
    { "cmd": "text", "char": "narrator", "body": "翌日、その少女が病で死んだことを、キリエは後から知った。" },
    { "cmd": "effect", "type": "glitch", "intensity": 0.3, "duration": 0.5, "color": "white" },
    { "cmd": "text", "char": "narrator", "body": "橋を渡り切ることはなかった。でも翌日、病が奪っていった。キリエが食べなかった意味は、なかったのかもしれなかった。" },
    { "cmd": "text", "char": "narrator", "body": "それ以来、キリエは人に近づかなかった。" },
    { "cmd": "text", "char": "narrator", "body": "近づいても、意味がないと思った。食べないことは選べても、守ることはできない。そういう存在だと思っていた。" },
    { "cmd": "effect", "type": "fade", "intensity": 0.6, "duration": 2.0, "color": "white" },
    { "cmd": "bg", "id": "river_bank", "transition": "crossfade" },
    { "cmd": "bgm", "id": "night_ambient", "fade": 3.0 },
    { "cmd": "sprite", "char": "saki", "pose": "sad", "position": "left" },
    { "cmd": "sprite", "char": "kirie", "pose": "normal", "position": "right" },
    { "cmd": "text", "char": "narrator", "body": "川の音が戻ってきた。" },
    { "cmd": "text", "char": "saki", "body": "……その子に会ったこと、ある。そんな気がした。" },
    { "cmd": "text", "char": "kirie", "body": "……似ている、と思ったことはある。" },
    { "cmd": "text", "char": "saki", "body": "あなたみたいな人が隣にいてくれたら、その子も少し違ったかも。" },
    { "cmd": "text", "char": "kirie", "body": "……いた。" },
    { "cmd": "text", "char": "saki", "body": "え？" },
    { "cmd": "text", "char": "kirie", "body": "隣にいた。一晩だけ。それで——翌日、病で死んだ。" },
    { "cmd": "text", "char": "saki", "body": "（あ。）" },
    { "cmd": "text", "char": "saki", "body": "……それで、人に近づかなくなったの。" },
    { "cmd": "text", "char": "kirie", "body": "意味がないと思った。私がそばにいても、守れない。ならば——いない方がいい。そう思っていた。" },
    { "cmd": "text", "char": "saki", "body": "……でも今、ここにいる。" },
    { "cmd": "text", "char": "kirie", "body": "……だから今夜、ここにいる。" },
    { "cmd": "text", "char": "narrator", "body": "川が流れていた。雪は降っていなかった。サキは柵から手を離さなかった——ただ、川を眺めていた。" },
    { "cmd": "text", "char": "narrator", "body": "逆真キリエは、五百万年越えて、また誰かの隣を選んだ。" },
    { "cmd": "text", "char": "narrator", "body": "その理由は、まだ二割、わからなかった。" }
  ]
}
