{
  "chapterId": "chapter04",
  "title": "第四章「サキの部屋」",
  "commands": [
    { "cmd": "bgm", "id": "melancholy_theme", "fade": 2.0 },
    { "cmd": "bg", "id": "saki_room", "transition": "fade" },
    { "cmd": "text", "char": "narrator", "body": "静かな昼下がりだった。窓から白い光が差し込んで、部屋の埃がゆっくりと浮いていた。" },
    { "cmd": "sprite", "char": "saki", "pose": "normal", "position": "left" },
    { "cmd": "text", "char": "narrator", "body": "サキはコタツに入って教科書を開いていた。開いているだけだった。目は文字の上にあったが、何も読んでいなかった。" },
    { "cmd": "text", "char": "saki", "body": "（数学。二次関数。……どうでもいい。）" },
    { "cmd": "text", "char": "narrator", "body": "ページをめくった。内容は変わったが、どうでもいいのは変わらなかった。" },
    { "cmd": "sprite", "char": "kirie", "pose": "normal", "position": "right" },
    { "cmd": "text", "char": "narrator", "body": "キリエは部屋の中を、音を立てずに歩いていた。歩くというより、漂うと言った方が正確だった。机、壁、窓、棚——一つずつ目に入れていた。" },
    { "cmd": "text", "char": "narrator", "body": "棚の上に、スケッチブックがあった。" },
    { "cmd": "sprite", "char": "kirie", "pose": "serious", "position": "right" },
    { "cmd": "text", "char": "narrator", "body": "キリエは立ち止まった。昼間に見たのと同じ、あのスケッチブックだ。今度は棚の上——少し高い場所に置いてある。手を伸ばした。" },
    { "cmd": "effect", "type": "flash", "intensity": 0.15, "duration": 0.4, "color": "white" },
    { "cmd": "text", "char": "narrator", "body": "止まった。" },
    { "cmd": "text", "char": "narrator", "body": "指先が表紙のすぐそばで、止まった。" },
    { "cmd": "text", "char": "saki", "body": "（あ。）" },
    { "cmd": "text", "char": "narrator", "body": "サキはコタツの中から、それを見ていた。教科書を持ったまま。" },
    { "cmd": "text", "char": "saki", "body": "（キリエが——止まってる。触れようとして、触れない。なんで？）" },
    { "cmd": "sprite", "char": "kirie", "pose": "normal", "position": "right" },
    { "cmd": "text", "char": "narrator", "body": "キリエは手を下ろした。スケッチブックを見たまま、何かを考えているようだった。" },
    { "cmd": "text", "char": "saki", "body": "……見ていいよ。" },
    { "cmd": "sprite", "char": "kirie", "pose": "surprised", "position": "right" },
    { "cmd": "text", "char": "narrator", "body": "キリエがサキを振り返った。珍しく、少し驚いた顔だった。" },
    { "cmd": "text", "char": "kirie", "body": "……いい。" },
    { "cmd": "text", "char": "saki", "body": "いいって、見なくていいの？" },
    { "cmd": "text", "char": "kirie", "body": "……許可がなかった。" },
    { "cmd": "text", "char": "saki", "body": "今許可したじゃん。" },
    { "cmd": "text", "char": "kirie", "body": "……もういい。見たいとは思っていない。ただ、触れていいかどうかが、わからなかっただけ。" },
    { "cmd": "text", "char": "saki", "body": "（なんか……変な子。でも、悪くない変な子。）" },
    { "cmd": "text", "char": "narrator", "body": "サキは教科書を閉じた。どうせ読んでいなかった。" },
    { "cmd": "bgm", "id": "saki_theme", "fade": 3.0 },
    { "cmd": "text", "char": "narrator", "body": "しばらく静かだった。キリエは窓の側に立って外を見ていた。サキはコタツで天井を眺めていた。" },
    { "cmd": "text", "char": "saki", "body": "ねえ、音楽聴く？" },
    { "cmd": "sprite", "char": "kirie", "pose": "normal", "position": "right" },
    { "cmd": "text", "char": "kirie", "body": "……音楽。" },
    { "cmd": "text", "char": "saki", "body": "うん。イヤホン一個貸すから、一緒に聴く？ 変な趣味かな、私の好きな曲。" },
    { "cmd": "text", "char": "kirie", "body": "……聴く。" },
    { "cmd": "sprite", "char": "saki", "pose": "normal", "position": "left" },
    { "cmd": "text", "char": "narrator", "body": "サキが枕の下からイヤホンを引っ張り出した。スマホに繋いで、片方をキリエに差し出した。" },
    { "cmd": "text", "char": "narrator", "body": "キリエはそれを受け取って、耳に当てた——当て方が少しぎこちなかった。" },
    { "cmd": "text", "char": "narrator", "body": "サキが再生した。ピアノと、細い弦の音。歌詞のない曲だった。" },
    { "cmd": "text", "char": "saki", "body": "（キリエ、目を閉じた。……聴いてる。）" },
    { "cmd": "text", "char": "narrator", "body": "曲が終わった。三分ちょっとの、短い曲だった。" },
    { "cmd": "text", "char": "kirie", "body": "……もう一度。" },
    { "cmd": "text", "char": "saki", "body": "え？" },
    { "cmd": "text", "char": "kirie", "body": "もう一度、流してほしい。" },
    { "cmd": "text", "char": "saki", "body": "……うん。" },
    { "cmd": "text", "char": "narrator", "body": "サキは再生した。二回目も、三分ちょっとだった。でも今度は違う長さに感じた。" },
    { "cmd": "text", "char": "saki", "body": "（気に入ったのかな。……なんか、それが嬉しいな。なんでだろう。）" },
    { "cmd": "text", "char": "narrator", "body": "窓の光が少し傾いた。部屋が薄橙色に染まり始めた。二人はイヤホンを一本ずつ持って、夕方を聴いていた。" },
    { "cmd": "text", "char": "kirie", "body": "……サキ。" },
    { "cmd": "text", "char": "saki", "body": "何。" },
    { "cmd": "text", "char": "kirie", "body": "……この曲の名前は。" },
    { "cmd": "text", "char": "saki", "body": "知らない。タイトルが英語でよくわかんなくて。でも好きな曲。" },
    { "cmd": "text", "char": "kirie", "body": "……そうか。" },
    { "cmd": "text", "char": "narrator", "body": "名前がわからなくても、好きになれる。キリエはそれを、今日初めて知った気がした。" }
  ]
}
