{
  "chapterId": "chapter08",
  "title": "間違い電話",
  "commands": [
    { "cmd": "bgm", "id": "night_ambient", "fade": 2.0 },
    { "cmd": "bg", "id": "saki_room", "transition": "fade" },
    { "cmd": "text", "char": "narrator", "body": "夜の部屋には、静かさだけが積もっていた。積もって、また積もって、やがて重さになる。" },
    { "cmd": "sprite", "char": "saki", "pose": "sad", "position": "center" },
    { "cmd": "text", "char": "narrator", "body": "入江サキは布団の上で膝を抱えていた。何もしていなかった。それが今夜の全部だった。" },
    { "cmd": "se", "id": "phone_ring" },
    { "cmd": "effect", "type": "flash", "intensity": 0.3, "duration": 0.4, "color": "white" },
    { "cmd": "text", "char": "saki", "body": "（……鳴ってる）" },
    { "cmd": "text", "char": "narrator", "body": "スマートフォンの画面が光る。着信。鈴村。その名前を見て、サキは指を動かさなかった。" },
    { "cmd": "text", "char": "saki", "body": "（出なくていい。今日は出なくていい）" },
    { "cmd": "sprite", "char": "kirie", "pose": "serious", "position": "left" },
    { "cmd": "text", "char": "narrator", "body": "窓際にいたキリエが、ゆっくりと振り向いた。" },
    { "cmd": "text", "char": "kirie", "body": "……あの光る板が、鳴いている。" },
    { "cmd": "text", "char": "saki", "body": "スマホ。電話がかかってきてる。" },
    { "cmd": "text", "char": "kirie", "body": "敵か。" },
    { "cmd": "text", "char": "saki", "body": "敵じゃないよ。ていうか敵って何。" },
    { "cmd": "sprite", "char": "kirie", "pose": "normal", "position": "left" },
    { "cmd": "text", "char": "kirie", "body": "振動し、光り、音を立て、お前を呼ぶ。警戒しないのか。" },
    { "cmd": "text", "char": "saki", "body": "（……なんかそう言われると、たしかに）" },
    { "cmd": "text", "char": "narrator", "body": "着信は切れた。部屋がまた静かになった。スマホの画面だけが、まだかすかに光っていた。" },
    { "cmd": "text", "char": "saki", "body": "……鈴村だった。昔の友達。" },
    { "cmd": "text", "char": "kirie", "body": "昔。" },
    { "cmd": "text", "char": "saki", "body": "うん。今はちょっと、よく分かんない関係。" },
    { "cmd": "text", "char": "kirie", "body": "……。" },
    { "cmd": "text", "char": "narrator", "body": "サキは画面を見た。着信履歴。鈴村からの着信、今夜で三回目だった。" },
    { "cmd": "text", "char": "saki", "body": "（三回。なんで三回もかけてくるんだろ）" },
    { "cmd": "text", "char": "saki", "body": "折り返し、しようかな。" },
    { "cmd": "text", "char": "kirie", "body": "折り返す。" },
    { "cmd": "text", "char": "saki", "body": "かけ直すってこと。" },
    { "cmd": "sprite", "char": "kirie", "pose": "surprised", "position": "left" },
    { "cmd": "text", "char": "kirie", "body": "折り返すというのは、何をすることか。文字通りに受け取れば、折って、戻す。電話をどう折るのか。" },
    { "cmd": "text", "char": "saki", "body": "……っ、折らないよ。電話をかけ直す、って意味で使う言葉なの。慣用表現。" },
    { "cmd": "text", "char": "kirie", "body": "……人間の言語は、文脈に依存しすぎる。" },
    { "cmd": "text", "char": "saki", "body": "はは。" },
    { "cmd": "text", "char": "narrator", "body": "笑い声が出た。小さく、意図せず。サキは少し驚いた——自分が笑ったことに。" },
    { "cmd": "text", "char": "saki", "body": "（あ。笑った)" },
    { "cmd": "sprite", "char": "kirie", "pose": "serious", "position": "left" },
    { "cmd": "text", "char": "kirie", "body": "かけ直すのか、かけ直さないのか。" },
    { "cmd": "text", "char": "saki", "body": "……かけてみる。" },
    { "cmd": "text", "char": "narrator", "body": "小さな決断だった。世界を変えない、ほとんど誰にも見えない——でも確かな一歩だった。サキは画面を押した。発信音が、静かな部屋に満ちた。" },
    { "cmd": "flag", "key": "FLAG_SAKI_CALLED_SUZUMURA", "value": "true" }
  ]
}
