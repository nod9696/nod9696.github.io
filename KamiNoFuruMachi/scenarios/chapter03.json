{
  "chapterId": "chapter03",
  "title": "第三章「夜の街へ」",
  "commands": [
    { "cmd": "bgm", "id": "night_ambient", "fade": 2.0 },
    { "cmd": "bg", "id": "saki_room", "transition": "fade" },
    { "cmd": "text", "char": "narrator", "body": "三日目の夜だった。" },
    { "cmd": "sprite", "char": "saki", "pose": "normal", "position": "left" },
    { "cmd": "sprite", "char": "kirie", "pose": "normal", "position": "right" },
    { "cmd": "text", "char": "saki", "body": "ねえ、出かけるって言ったじゃん。どこ連れてく気？" },
    { "cmd": "text", "char": "kirie", "body": "……街。" },
    { "cmd": "text", "char": "saki", "body": "それだけ？ 夜の街ってコンビニくらいしかないんだけど。" },
    { "cmd": "text", "char": "kirie", "body": "……それでいい。" },
    { "cmd": "text", "char": "narrator", "body": "サキはため息をついてから、上着を羽織った。キリエは最初からコートを着ていた——いつ着たのか、サキは見ていなかった。" },
    { "cmd": "bg", "id": "night_city", "transition": "fade" },
    { "cmd": "bgm", "id": "city_ambient", "fade": 2.0 },
    { "cmd": "text", "char": "narrator", "body": "夜の商店街は明るかった。蛍光灯の白い光が路面を照らし、まばらな人影が行き来している。" },
    { "cmd": "sprite", "char": "saki", "pose": "normal", "position": "left" },
    { "cmd": "sprite", "char": "kirie", "pose": "serious", "position": "right" },
    { "cmd": "text", "char": "saki", "body": "（キリエって外出るのあんまり慣れてないのかな。なんか……緊張してる？）" },
    { "cmd": "text", "char": "narrator", "body": "キリエの歩調が少し遅い。目が細かく動いている。看板、人、光、音。全部を処理しようとしているみたいだった。" },
    { "cmd": "bg", "id": "convenience_store", "transition": "cut" },
    { "cmd": "bgm", "id": "city_ambient", "fade": 1.0 },
    { "cmd": "text", "char": "narrator", "body": "コンビニの自動ドアが開いた。" },
    { "cmd": "se", "id": "door_open" },
    { "cmd": "sprite", "char": "kirie", "pose": "surprised", "position": "right" },
    { "cmd": "text", "char": "narrator", "body": "キリエが一歩後ずさった。ほんの少しだけ、でも確かに。" },
    { "cmd": "text", "char": "saki", "body": "……え、びくってした？ 自動ドアで？" },
    { "cmd": "text", "char": "kirie", "body": "……動いた。" },
    { "cmd": "text", "char": "saki", "body": "扉が？ そりゃ開くでしょ。自動ドアだから。" },
    { "cmd": "text", "char": "kirie", "body": "……知っている。驚いた、それだけ。" },
    { "cmd": "text", "char": "saki", "body": "「知ってる」って言いながら驚くんだね。五百万年生きてて自動ドアに驚くの、ちょっと面白いな。" },
    { "cmd": "sprite", "char": "kirie", "pose": "normal", "position": "right" },
    { "cmd": "text", "char": "narrator", "body": "キリエはサキを見た。サキが笑っていた——小さく、でも確かに。" },
    { "cmd": "text", "char": "narrator", "body": "店内に入った。蛍光灯が眩しく、陳列棚が続いていた。レジの店員が二人のことをちらりと見た。" },
    { "cmd": "sprite", "char": "saki", "pose": "normal", "position": "left" },
    { "cmd": "sprite", "char": "kirie", "pose": "normal", "position": "right" },
    { "cmd": "text", "char": "saki", "body": "何か食べる？ ……食べれるの、キリエ。" },
    { "cmd": "text", "char": "kirie", "body": "……たまに。" },
    { "cmd": "text", "char": "saki", "body": "あいまいな答えだな。じゃあおにぎり。食べたことある？" },
    { "cmd": "text", "char": "kirie", "body": "……ない。" },
    { "cmd": "text", "char": "saki", "body": "じゃあ買う。" },
    { "cmd": "se", "id": "vending_machine" },
    { "cmd": "text", "char": "narrator", "body": "サキがおにぎりを二つ手に取った。ツナマヨと昆布。レジで清算して、外のベンチに腰かけた。" },
    { "cmd": "text", "char": "saki", "body": "開け方わかる？ 1、2、3って書いてある通りにやるだけ。" },
    { "cmd": "text", "char": "kirie", "body": "……一。二。三。" },
    { "cmd": "se", "id": "glass_break" },
    { "cmd": "text", "char": "narrator", "body": "パリパリ、と気持ちのいい音がした。フィルムが剥がれて、おにぎりが手の中に現れた。キリエは少しの間それを見ていた。" },
    { "cmd": "text", "char": "kirie", "body": "……剥がれた。" },
    { "cmd": "text", "char": "saki", "body": "剥がれた、って。そりゃ剥がれるよ。食べてみて。" },
    { "cmd": "text", "char": "narrator", "body": "キリエはゆっくりと一口かじった。咀嚼する。飲み込む。何かを考えている顔だった。" },
    { "cmd": "text", "char": "kirie", "body": "……しょっぱい。" },
    { "cmd": "text", "char": "saki", "body": "昆布だから。美味しい？" },
    { "cmd": "text", "char": "kirie", "body": "……わからない。でも、食べられる。" },
    { "cmd": "text", "char": "saki", "body": "それでいいんじゃない。" },
    { "cmd": "bgm", "id": "kirie_hunt", "fade": 2.5 },
    { "cmd": "text", "char": "narrator", "body": "少し間があって、サキが聞いた。" },
    { "cmd": "text", "char": "saki", "body": "狩りって、どうやってやるの。白蝕とか言ってたやつ。" },
    { "cmd": "sprite", "char": "kirie", "pose": "serious", "position": "right" },
    { "cmd": "text", "char": "kirie", "body": "夜に出る。それだけ。" },
    { "cmd": "text", "char": "saki", "body": "それだけって……見つけ方とか、倒し方とか。" },
    { "cmd": "text", "char": "kirie", "body": "感じる。近づく。消す。" },
    { "cmd": "text", "char": "saki", "body": "三段階で説明できるんだ。……怖くないの？" },
    { "cmd": "text", "char": "kirie", "body": "……怖いという感情が、よくわからない。" },
    { "cmd": "text", "char": "saki", "body": "（それはそれで怖いな、という感想が出かかって、やめた。）" },
    { "cmd": "text", "char": "narrator", "body": "夜風が吹いた。サキはコートの前を合わせた。キリエは動かなかった。" },
    { "cmd": "sprite", "char": "kirie", "pose": "normal", "position": "right" },
    { "cmd": "effect", "type": "glitch", "intensity": 0.3, "duration": 0.5, "color": "white" },
    { "cmd": "text", "char": "narrator", "body": "キリエの目が細くなった。夜の方を向いた。" },
    { "cmd": "text", "char": "saki", "body": "……どうしたの？" },
    { "cmd": "text", "char": "kirie", "body": "気配がした。" },
    { "cmd": "text", "char": "saki", "body": "白蝕？" },
    { "cmd": "text", "char": "kirie", "body": "……まだいない。近くにいたが、行った。" },
    { "cmd": "text", "char": "saki", "body": "今夜は大丈夫ってこと？" },
    { "cmd": "text", "char": "kirie", "body": "今夜は。" },
    { "cmd": "text", "char": "narrator", "body": "サキはその「今夜は」という言葉の後ろにある省略を、あまり深く考えないことにした。" },
    { "cmd": "text", "char": "narrator", "body": "帰り道、二人は並んで歩いた。会話は少なかった。でもそれは気まずいのとは違った。" },
    { "cmd": "text", "char": "saki", "body": "ね、また来てもいい？ コンビニ。" },
    { "cmd": "text", "char": "kirie", "body": "……好きにすれば。" },
    { "cmd": "text", "char": "saki", "body": "それ、イエスってこと？" },
    { "cmd": "text", "char": "kirie", "body": "……イエス。" },
    { "cmd": "text", "char": "narrator", "body": "夜は静かに、少しだけ柔らかかった。" }
  ]
}
