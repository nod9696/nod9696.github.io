{
  "chapterId": "chapter05",
  "title": "第五章「先を越した何か」",
  "commands": [
    { "cmd": "bgm", "id": "morning_ambient", "fade": 2.0 },
    { "cmd": "bg", "id": "saki_room_morning", "transition": "fade" },
    { "cmd": "text", "char": "narrator", "body": "スマホが震えた。" },
    { "cmd": "se", "id": "alarm_clock" },
    { "cmd": "sprite", "char": "saki", "pose": "normal", "position": "center" },
    { "cmd": "text", "char": "saki", "body": "（鈴村から……LINE？）" },
    { "cmd": "text", "char": "narrator", "body": "メッセージはこうだった。「学校来れる？ ちょっと聞きたいことあって」" },
    { "cmd": "text", "char": "saki", "body": "（鈴村。小学校からの友達。でも最近ほとんど連絡とってなかった。……聞きたいことって何だろう。）" },
    { "cmd": "sprite", "char": "kirie", "pose": "normal", "position": "right" },
    { "cmd": "text", "char": "kirie", "body": "……行くのか？" },
    { "cmd": "text", "char": "saki", "body": "うわ、声かけないでよ、びっくりした。……うん、行く、かな。久しぶりだし。" },
    { "cmd": "text", "char": "kirie", "body": "……ついていく。" },
    { "cmd": "text", "char": "saki", "body": "は？ 勝手に来るの？ 学校だよ。" },
    { "cmd": "text", "char": "kirie", "body": "……近くにいる。" },
    { "cmd": "text", "char": "saki", "body": "（止めても来るんだろうな、この子は。……まあいいか。）" },
    { "cmd": "bg", "id": "high_school_entrance", "transition": "fade" },
    { "cmd": "bgm", "id": "city_ambient", "fade": 2.0 },
    { "cmd": "text", "char": "narrator", "body": "学校の昇降口は人の少ない時間帯だった。放課後の少し前——部活が始まる前の、中途半端な空白の時間。" },
    { "cmd": "sprite", "char": "saki", "pose": "normal", "position": "left" },
    { "cmd": "sprite", "char": "kirie", "pose": "normal", "position": "right" },
    { "cmd": "text", "char": "saki", "body": "（鈴村、どこにいるんだろう。メッセージしてみる——）" },
    { "cmd": "effect", "type": "glitch", "intensity": 0.5, "duration": 0.6, "color": "white" },
    { "cmd": "bgm", "id": "tense_music", "fade": 1.0 },
    { "cmd": "text", "char": "narrator", "body": "空気が変わった。" },
    { "cmd": "sprite", "char": "kirie", "pose": "serious", "position": "right" },
    { "cmd": "text", "char": "saki", "body": "（——なに、これ。）" },
    { "cmd": "text", "char": "narrator", "body": "昇降口の奥、下駄箱の影から何かが滲んでいた。白い。光ではなく、光の逆のもの——あらゆる色を吸い込む白さ。輪郭がなく、それでいて確かにそこにあった。" },
    { "cmd": "text", "char": "saki", "body": "（足が、動かない。）" },
    { "cmd": "effect", "type": "shake", "intensity": 0.4, "duration": 0.8, "color": "white" },
    { "cmd": "text", "char": "narrator", "body": "白いものが近づいてきた。音はなかった。臭いもなかった。ただ——静けさが増した。世界の音量が下がっていくみたいに。" },
    { "cmd": "text", "char": "saki", "body": "（これが白蝕。……怖い。怖いのに、足が動かない。身体が、重い。）" },
    { "cmd": "text", "char": "saki", "body": "（白い静けさが、なんか——楽だ。楽なのが、怖い。）" },
    { "cmd": "text", "char": "narrator", "body": "白蝕はサキの感情に共鳴する。死を望む感情を、静けさに変える。その静けさは本物の安らぎに似ている——でも、違う。" },
    { "cmd": "text", "char": "saki", "body": "（でも——これは私のじゃない。）" },
    { "cmd": "text", "char": "saki", "body": "（私が死にたいのは、私が決めることだ。こんな白いもやに、決められたくない。嫌だ。）" },
    { "cmd": "effect", "type": "flash", "intensity": 0.8, "duration": 0.5, "color": "white" },
    { "cmd": "sprite", "char": "kirie", "pose": "serious", "position": "center" },
    { "cmd": "text", "char": "narrator", "body": "キリエが前に出た。" },
    { "cmd": "text", "char": "narrator", "body": "白蝕に向かって歩いた。ゆっくりと、しかし迷いなく。右手を上げた。指先が白い霧に触れた——触れた瞬間、白い霧がぶれた。震えた。縮んだ。" },
    { "cmd": "effect", "type": "fade", "intensity": 1.0, "duration": 1.2, "color": "white" },
    { "cmd": "text", "char": "narrator", "body": "消えた。" },
    { "cmd": "bgm", "id": "melancholy_theme", "fade": 2.0 },
    { "cmd": "bg", "id": "high_school_entrance", "transition": "crossfade" },
    { "cmd": "sprite", "char": "saki", "pose": "sad", "position": "left" },
    { "cmd": "sprite", "char": "kirie", "pose": "normal", "position": "right" },
    { "cmd": "text", "char": "narrator", "body": "昇降口にはまた普通の空気が戻った。遠くで部活の声がした。" },
    { "cmd": "text", "char": "saki", "body": "……何だったの、今の。" },
    { "cmd": "text", "char": "kirie", "body": "白蝕。言っていた通りの。" },
    { "cmd": "text", "char": "saki", "body": "あんな……近くで見たことなかった。ていうか見たこともないか。……起源って何なの、あれ。なんで人を狙うの。" },
    { "cmd": "sprite", "char": "kirie", "pose": "serious", "position": "right" },
    { "cmd": "text", "char": "kirie", "body": "白蝕は感情の澱だ。人間が長い年月をかけて積み上げた、死への傾きが結晶したもの。" },
    { "cmd": "text", "char": "kirie", "body": "人を狙うのではなく——人の中にある感情の隙間を、埋めようとする。その隙間が大きいほど、引き寄せられる。" },
    { "cmd": "text", "char": "saki", "body": "……私が引き寄せたってこと？" },
    { "cmd": "text", "char": "kirie", "body": "……そうなる。" },
    { "cmd": "text", "char": "saki", "body": "（やっぱりそうか。……でも、嫌だって思った。それは本物だった。）" },
    { "cmd": "text", "char": "kirie", "body": "サキ。" },
    { "cmd": "text", "char": "saki", "body": "何。" },
    { "cmd": "text", "char": "kirie", "body": "見たくないものを、ちゃんと見ていた。" },
    { "cmd": "text", "char": "saki", "body": "……は？" },
    { "cmd": "text", "char": "kirie", "body": "目を逸らさなかった。怖いと感じながら、自分の感情を手放さなかった。それは……難しいことだ。" },
    { "cmd": "text", "char": "saki", "body": "（キリエが、褒めてる？ 褒め方が独特すぎて一瞬わからなかった。）" },
    { "cmd": "text", "char": "saki", "body": "……ありがと。たぶん。" },
    { "cmd": "flag", "key": "HAKUSHOKU_FIRST_ENCOUNTER", "value": "true" },
    { "cmd": "sprite", "char": "suzumura", "pose": "normal", "position": "center" },
    { "cmd": "se", "id": "footsteps" },
    { "cmd": "text", "char": "suzumura", "body": "サキ！ 来てたんだ。ごめんね待たせて——あれ、この子誰？" },
    { "cmd": "sprite", "char": "saki", "pose": "normal", "position": "left" },
    { "cmd": "text", "char": "saki", "body": "あ、鈴村。えっと……知り合い。" },
    { "cmd": "sprite", "char": "kirie", "pose": "normal", "position": "right" },
    { "cmd": "text", "char": "kirie", "body": "……逆真。" },
    { "cmd": "text", "char": "suzumura", "body": "逆真さん。変わった名前だね、よろしく！ サキの友達？" },
    { "cmd": "text", "char": "kirie", "body": "……近い。" },
    { "cmd": "text", "char": "saki", "body": "（近い、ってなんだよ。でも——まあ、嘘でもないか。）" },
    { "cmd": "text", "char": "narrator", "body": "昇降口に夕方の光が差し込んできた。さっきの白い静けさは、もうどこにもなかった。" }
  ]
}
