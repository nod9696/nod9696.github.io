{
  "chapterId": "chapter11",
  "title": "白が満ちる夜に",
  "commands": [
    { "cmd": "bgm", "id": "tense_music", "fade": 2.0 },
    { "cmd": "bg", "id": "saki_room", "transition": "cut" },
    { "cmd": "text", "char": "narrator", "body": "午後十一時。部屋の空気が変わった——サキには分からない変化だった。しかしキリエには分かった。" },
    { "cmd": "sprite", "char": "kirie", "pose": "serious", "position": "left" },
    { "cmd": "sprite", "char": "saki", "pose": "normal", "position": "center" },
    { "cmd": "text", "char": "kirie", "body": "……。" },
    { "cmd": "text", "char": "narrator", "body": "キリエは窓の外を向いたまま、動かなかった。立ち尽くしていた——というより、感知していた。白いものが、夜の街に満ちていくのを。" },
    { "cmd": "text", "char": "saki", "body": "なに見てるの。" },
    { "cmd": "text", "char": "kirie", "body": "白蝕。複数いる。" },
    { "cmd": "text", "char": "saki", "body": "複数って——何体くらい？" },
    { "cmd": "text", "char": "kirie", "body": "……四体。いや。五体。" },
    { "cmd": "effect", "type": "glitch", "intensity": 0.4, "duration": 0.5 },
    { "cmd": "text", "char": "kirie", "body": "同時に来たことはなかった。" },
    { "cmd": "text", "char": "saki", "body": "それってやばいやつ？" },
    { "cmd": "text", "char": "kirie", "body": "少しここを離れる。" },
    { "cmd": "text", "char": "narrator", "body": "キリエが外套を手に取った。その瞬間、サキは立ち上がった。" },
    { "cmd": "sprite", "char": "saki", "pose": "serious", "position": "center" },
    { "cmd": "text", "char": "saki", "body": "連れていって。" },
    { "cmd": "text", "char": "kirie", "body": "危険だ。" },
    { "cmd": "text", "char": "saki", "body": "ここにいる方が怖い。一人で待ってる方が。" },
    { "cmd": "text", "char": "kirie", "body": "……危険の量は変わらない。" },
    { "cmd": "text", "char": "saki", "body": "一緒に怖い方が一倍で済むじゃん。一人で怖いのと、一人で怖いのがある方が二倍でしょ。" },
    { "cmd": "text", "char": "kirie", "body": "……その論理は、計算が合っていない。" },
    { "cmd": "text", "char": "saki", "body": "合ってるよ。情緒的に合ってる。" },
    { "cmd": "text", "char": "narrator", "body": "サキはキリエの袖を掴んだ。キリエは少し下を向いた。それから、短く息をついた。" },
    { "cmd": "text", "char": "kirie", "body": "……動くな。私の隣から離れるな。" },
    { "cmd": "bgm", "id": "tense_music", "fade": 1.0 },
    { "cmd": "bg", "id": "night_city", "transition": "fade" },
    { "cmd": "text", "char": "narrator", "body": "夜の街は静かだった。静かすぎた。人の気配がなく、灯りも少なく、白いものが霧のように漂っていた。" },
    { "cmd": "sprite", "char": "kirie", "pose": "serious", "position": "left" },
    { "cmd": "sprite", "char": "saki", "pose": "serious", "position": "right" },
    { "cmd": "text", "char": "narrator", "body": "一体目。路地の角に溜まっていた白が、形を成した。キリエが前に出た。一瞬。光もなく、音もなく、白蝕は散った。" },
    { "cmd": "text", "char": "saki", "body": "（……すごい。いつ見ても）" },
    { "cmd": "text", "char": "narrator", "body": "二体目は橋の上にいた。三体目は川沿いの暗がりに。四体目は公園の木陰に——いずれも、同じだった。キリエが触れると、消えた。" },
    { "cmd": "effect", "type": "shake", "intensity": 0.3, "duration": 0.4 },
    { "cmd": "text", "char": "saki", "body": "……あと一体？" },
    { "cmd": "text", "char": "kirie", "body": "……違う。" },
    { "cmd": "effect", "type": "glitch", "intensity": 0.7, "duration": 0.8 },
    { "cmd": "text", "char": "narrator", "body": "キリエが止まった。夜の空気が、重くなった——物理的な重さではなく、何か別の密度で。" },
    { "cmd": "sprite", "char": "kirie", "pose": "serious", "position": "left" },
    { "cmd": "text", "char": "kirie", "body": "……根にいる。" },
    { "cmd": "text", "char": "saki", "body": "根？" },
    { "cmd": "text", "char": "kirie", "body": "四体を束ねた、中心がいる。あの四体はそれの枝葉だ。" },
    { "cmd": "effect", "type": "shake", "intensity": 0.5, "duration": 0.6 },
    { "cmd": "text", "char": "saki", "body": "……でかいの来た、ってこと？" },
    { "cmd": "text", "char": "kirie", "body": "……やってみる。" },
    { "cmd": "sprite", "char": "kirie", "pose": "serious", "position": "left" },
    { "cmd": "text", "char": "kirie", "body": "本当に動くな。" },
    { "cmd": "text", "char": "saki", "body": "分かった。" },
    { "cmd": "text", "char": "narrator", "body": "キリエは前に出た。夜が、白くなっていった。" },
    { "cmd": "flag", "key": "HAKUSHOKU_MULTIPLE", "value": "true" }
  ]
}
