# note.com 投稿設定
# このファイルを .env にコピーして使用してください

# ブログ記事の保存ディレクトリ
BLOG_DIR=f:/Claude

# note.com のユーザー名（プロフィールURL の @以降）
# 例: https://note.com/username → NOTE_USERNAME=username
NOTE_USERNAME=your_note_username

# 投稿タグ（カンマ区切り）
NOTE_TAGS=インディーゲーム,ゲームレビュー,Steam

# ヘッドレスモード（true=バックグラウンド実行 / false=ブラウザ表示）
HEADLESS=true
