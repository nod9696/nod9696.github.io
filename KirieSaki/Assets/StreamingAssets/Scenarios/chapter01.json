{
  "chapterId": "chapter01",
  "title": "第一章「翌朝、まだいる」",
  "commands": [
    { "cmd": "bgm", "id": "night_ambient", "fade": 2.0 },
    { "cmd": "bg", "id": "saki_room", "transition": "fade" },
    { "cmd": "sprite", "char": "kirie", "pose": "normal", "position": "left" },
    { "cmd": "text", "char": "narrator", "body": "夜明けまで——キリエはそこにいた。" },
    { "cmd": "text", "char": "narrator", "body": "理由は、わからない。" },
    { "cmd": "text", "char": "narrator", "body": "食事も終えていないのに、立ち去るという選択肢が浮かばなかった。" },
    { "cmd": "text", "char": "narrator", "body": "少女が眠っている。窓際の薄明かりが、寝顔を淡く縁取っていた。" },
    { "cmd": "text", "char": "kirie", "body": "……おやすみ、とはどういう意味か。" },
    { "cmd": "text", "char": "narrator", "body": "声に出してみた。誰に聞くでもなく。" },
    { "cmd": "text", "char": "kirie", "body": "夜の安寧を願う言葉——か。" },
    { "cmd": "text", "char": "narrator", "body": "試しに言ってみたら、少女は布団に潜って出てこなかった。因果が不明だった。" },
    { "cmd": "bgm", "id": "morning_ambient", "fade": 3.0 },
    { "cmd": "bg", "id": "saki_room_morning", "transition": "fade" },
    { "cmd": "se", "id": "alarm_clock" },
    { "cmd": "text", "char": "narrator", "body": "朝が来た。" },
    { "cmd": "sprite", "char": "saki", "pose": "surprised", "position": "right" },
    { "cmd": "text", "char": "saki", "body": "……まだいる。" },
    { "cmd": "text", "char": "kirie", "body": "ああ。" },
    { "cmd": "text", "char": "saki", "body": "なんで。" },
    { "cmd": "text", "char": "kirie", "body": "……わからない。" },
    { "cmd": "text", "char": "saki", "body": "わからないのに居るの？" },
    { "cmd": "text", "char": "kirie", "body": "そうなる。" },
    { "cmd": "text", "char": "saki", "body": "（何この子、独特すぎる……）まあ、いいけど。コーヒー飲む？" },
    { "cmd": "text", "char": "kirie", "body": "……人間の飲み物か。" },
    { "cmd": "text", "char": "saki", "body": "飲んだことない？" },
    { "cmd": "text", "char": "kirie", "body": "ない。" },
    { "cmd": "text", "char": "saki", "body": "（ない、って言い切るんだ……）" },
    { "cmd": "se", "id": "kitchen_sounds" },
    { "cmd": "text", "char": "narrator", "body": "サキがキッチンへ。カップを二つ並べた。" },
    { "cmd": "text", "char": "saki", "body": "砂糖、何杯入れる？" },
    { "cmd": "text", "char": "kirie", "body": "……杯数の基準がわからない。" },
    { "cmd": "text", "char": "saki", "body": "じゃあ一杯から試そっか。" },
    { "cmd": "text", "char": "narrator", "body": "一杯。" },
    { "cmd": "text", "char": "kirie", "body": "……苦い。" },
    { "cmd": "text", "char": "saki", "body": "二杯は？" },
    { "cmd": "text", "char": "narrator", "body": "二杯。" },
    { "cmd": "text", "char": "kirie", "body": "……まだ苦い。" },
    { "cmd": "text", "char": "saki", "body": "三杯——" },
    { "cmd": "text", "char": "narrator", "body": "三杯。" },
    { "cmd": "text", "char": "kirie", "body": "……許容できる。" },
    { "cmd": "text", "char": "saki", "body": "三杯ね。覚えてて。" },
    { "cmd": "text", "char": "saki", "body": "（なんか実験みたいだったけど——まあ、そう悪くもなかった）" },
    { "cmd": "flag", "key": "FLAG_SUGAR_EXPERIMENT", "value": "3" },
    { "cmd": "text", "char": "narrator", "body": "キリエは自分がなぜ砂糖の杯数を記憶しようとしているのか、よくわからなかった。" },
    { "cmd": "text", "char": "narrator", "body": "ただ在る、ということの話になった。自然と、流れるように。" },
    { "cmd": "text", "char": "kirie", "body": "お前はなぜここにいる。" },
    { "cmd": "text", "char": "saki", "body": "えー……居場所があるから、かな。" },
    { "cmd": "text", "char": "kirie", "body": "居場所とは。" },
    { "cmd": "text", "char": "saki", "body": "自分がいてもいい場所、みたいな。" },
    { "cmd": "text", "char": "kirie", "body": "……いてもいいかどうかを、どう判断する。" },
    { "cmd": "text", "char": "saki", "body": "いていいって言ってくれる人が——いるかどうか、かも。" },
    { "cmd": "text", "char": "narrator", "body": "キリエが、黙った。" },
    { "cmd": "text", "char": "narrator", "body": "長い沈黙。コーヒーの湯気だけが細く昇っていた。" },
    { "cmd": "text", "char": "kirie", "body": "……お前がいてもいいと言うなら、ここにいる。" },
    { "cmd": "text", "char": "saki", "body": "……。" },
    { "cmd": "text", "char": "saki", "body": "……いてもいいよ。" },
    { "cmd": "text", "char": "narrator", "body": "こうして逆真キリエは、入江サキの部屋に居着いた。" },
    { "cmd": "text", "char": "narrator", "body": "理由は——まだ、よくわからなかった。" },
    { "cmd": "flag", "key": "FLAG_KIRIE_STAYED", "value": "true" },
    { "cmd": "flag", "key": "CHAPTER01_COMPLETE", "value": "true" }
  ]
}
