{
  "chapterId": "chapter14",
  "title": "後日談「砂糖なしの朝に」",
  "commands": [
    { "cmd": "bgm", "id": "morning_ambient", "fade": 3.0 },
    { "cmd": "bg", "id": "saki_room_morning", "transition": "fade" },
    { "cmd": "text", "char": "narrator", "body": "数週間後の朝。" },
    { "cmd": "text", "char": "narrator", "body": "あるいは数ヶ月後かもしれない。どちらでもよかった。" },
    { "cmd": "sprite", "char": "saki", "pose": "normal", "position": "right" },
    { "cmd": "se", "id": "kitchen_sounds" },
    { "cmd": "text", "char": "narrator", "body": "サキがコーヒーを淹れている。手が勝手に動いていた。マグカップを、二つ。" },
    { "cmd": "text", "char": "narrator", "body": "砂糖を取り出す。考える前に、三杯。" },
    { "cmd": "text", "char": "narrator", "body": "もう体が知っていた。" },
    { "cmd": "sprite", "char": "kirie", "pose": "soliloquy", "position": "left" },
    { "cmd": "text", "char": "narrator", "body": "キリエは窓際にいた。外を見ている。朝の街。人が動き始めている。" },
    { "cmd": "text", "char": "narrator", "body": "いつもの場所。いつもの時間。" },
    { "cmd": "text", "char": "saki", "body": "できた。" },
    { "cmd": "sprite", "char": "kirie", "pose": "normal", "position": "left" },
    { "cmd": "text", "char": "narrator", "body": "サキがマグカップをキリエの前に置いた。砂糖三杯。" },
    { "cmd": "text", "char": "kirie", "body": "……ありがとう。" },
    { "cmd": "text", "char": "saki", "body": "どういたしまして。" },
    { "cmd": "text", "char": "narrator", "body": "サキはソファに座った。コーヒーを一口飲んだ。しばらく、何も言わなかった。" },
    { "cmd": "text", "char": "narrator", "body": "それでよかった。" },
    { "cmd": "se", "id": "alarm_clock" },
    { "cmd": "sprite", "char": "saki", "pose": "normal", "position": "right" },
    { "cmd": "text", "char": "saki", "body": "あ、鈴村だ。ちょっと待って。——もしもし？" },
    { "cmd": "text", "char": "narrator", "body": "キリエはコーヒーを持ったまま、サキの話を聞いていた。" },
    { "cmd": "text", "char": "saki", "body": "うん、昨日の件ね。——ちょっと今手が離せなくて、あとでかけ直していい？　うん、またね。" },
    { "cmd": "text", "char": "narrator", "body": "電話が終わった。" },
    { "cmd": "sprite", "char": "kirie", "pose": "normal", "position": "left" },
    { "cmd": "text", "char": "kirie", "body": "『あとで話す』と言った。" },
    { "cmd": "text", "char": "saki", "body": "うん。" },
    { "cmd": "text", "char": "kirie", "body": "社交辞令か。" },
    { "cmd": "sprite", "char": "saki", "pose": "smile", "position": "right" },
    { "cmd": "text", "char": "saki", "body": "違う。本当にあとでかけ直す。" },
    { "cmd": "text", "char": "kirie", "body": "……そうか。" },
    { "cmd": "text", "char": "saki", "body": "社交辞令と本当の区別、少しはわかってきた？" },
    { "cmd": "text", "char": "kirie", "body": "……わかる。" },
    { "cmd": "sprite", "char": "saki", "pose": "smile", "position": "right" },
    { "cmd": "text", "char": "narrator", "body": "サキが笑った。" },
    { "cmd": "text", "char": "narrator", "body": "キリエはその笑顔を見た。数えなかった。数える必要がない、という気がした。" },
    { "cmd": "sprite", "char": "kirie", "pose": "normal", "position": "left" },
    { "cmd": "text", "char": "narrator", "body": "キリエはコーヒーを一口飲んだ。砂糖三杯。四十八杯目。" },
    { "cmd": "text", "char": "kirie", "body": "……許容できる。" },
    { "cmd": "text", "char": "saki", "body": "知ってる。" },
    { "cmd": "text", "char": "narrator", "body": "窓の外で、朝が動いている。" },
    { "cmd": "bgm", "id": "saki_theme", "fade": 4.0 },
    { "cmd": "text", "char": "narrator", "body": "二人で飲んでいた。" },
    { "cmd": "text", "char": "narrator", "body": "五十万七千三十六回の夜の果てに——朝があった。" },
    { "cmd": "text", "char": "narrator", "body": "今日も、明日も。" },
    { "cmd": "flag", "key": "CHAPTER14_COMPLETE", "value": "true" }
  ]
}
