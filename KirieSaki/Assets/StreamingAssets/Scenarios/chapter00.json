{
  "chapterId": "chapter00",
  "title": "序章「逆しまに月が落ちていく」",
  "commands": [
    { "cmd": "bgm", "id": "night_ambient", "fade": 3.0 },
    { "cmd": "bg", "id": "night_sky", "transition": "fade" },
    { "cmd": "text", "char": "narrator", "body": "逆しまに、月が落ちていく。" },
    { "cmd": "text", "char": "narrator", "body": "星のない夜。果てしないパノラマ。" },
    { "cmd": "text", "char": "narrator", "body": "少女の肉体が、映画のコマのように空を裂く。" },
    { "cmd": "effect", "type": "shake", "intensity": 0.9, "duration": 1.2 },
    { "cmd": "text", "char": "narrator", "body": "轟音。白光。衝撃。" },
    { "cmd": "effect", "type": "flash", "duration": 0.4 },
    { "cmd": "text", "char": "narrator", "body": "塵以下の質量が大地を知る——霧散し、数刻のちに形を取り戻した。" },
    { "cmd": "text", "char": "narrator", "body": "またか。" },
    { "cmd": "text", "char": "narrator", "body": "逆真キリエの感慨は、その二文字で事足りた。" },
    { "cmd": "text", "char": "narrator", "body": "五十万と七千、三十六回目。死は今日も仕事を果たさなかった。" },
    { "cmd": "text", "char": "narrator", "body": "終わりのないループ。変数だけが積み上がる。" },
    { "cmd": "text", "char": "narrator", "body": "——それでも喉だけはカラカラに乾く。鬱陶しい。" },
    { "cmd": "bgm", "id": "kirie_hunt", "fade": 1.5 },
    { "cmd": "bg", "id": "night_city", "transition": "fade" },
    { "cmd": "text", "char": "narrator", "body": "夜間飛行、再開。涼風を裂いて。死の匂いを羅針盤に。" },
    { "cmd": "text", "char": "narrator", "body": "それは鼻腔をついた——死の匂いとは異なる、もっと切実な何かが。" },
    { "cmd": "bg", "id": "apartment_window", "transition": "fade" },
    { "cmd": "text", "char": "narrator", "body": "アパート五階。窓辺に黒髪の少女。" },
    { "cmd": "text", "char": "narrator", "body": "佇んでいた。夜を眺めるように。あるいは夜に飲まれるように。" },
    { "cmd": "sprite", "char": "kirie", "pose": "normal", "position": "left" },
    { "cmd": "text", "char": "kirie", "body": "……。" },
    { "cmd": "sprite", "char": "saki", "pose": "normal", "position": "right" },
    { "cmd": "text", "char": "narrator", "body": "五階への突然の来訪者。少女は驚かなかった。——驚く余力も、なかった。" },
    { "cmd": "bg", "id": "saki_room", "transition": "fade" },
    { "cmd": "text", "char": "narrator", "body": "窓を閉める。床にへたりと座り込む。皿に盛りつけられたように、脱力して動かない。" },
    { "cmd": "text", "char": "narrator", "body": "月に照らされた今夜の食事は、場違いなくらい美しかった。" },
    { "cmd": "text", "char": "kirie", "body": "……記憶した。" },
    { "cmd": "text", "char": "narrator", "body": "首筋へ俯いた瞬間。" },
    { "cmd": "effect", "type": "shake", "intensity": 0.6, "duration": 0.7 },
    { "cmd": "text", "char": "narrator", "body": "ギャン泣きだった。" },
    { "cmd": "text", "char": "narrator", "body": "十年分積み重ねたような慟哭が部屋ごと揺れている。美しかったディナーは各種液体に濡れた。" },
    { "cmd": "se", "id": "glass_break" },
    { "cmd": "text", "char": "narrator", "body": "困った。キリエが困ったのは七万三千年ぶりくらいだった。" },
    { "cmd": "text", "char": "narrator", "body": "焦燥に駆られた牙が向かった先は——首筋ではなく、騒音の大本、少女の口だった。" },
    { "cmd": "effect", "type": "flash", "duration": 0.3 },
    { "cmd": "text", "char": "narrator", "body": "痛いほどの静寂。" },
    { "cmd": "text", "char": "narrator", "body": "黒く大きな瞳が、じっとキリエを見ていた。" },
    { "cmd": "text", "char": "narrator", "body": "逆真キリエの五十万七千三十六回目の自殺企図は、こうして——成功した。" },
    { "cmd": "bgm", "id": "saki_theme", "fade": 2.0 },
    { "cmd": "sprite", "char": "saki", "pose": "normal", "position": "center" },
    { "cmd": "text", "char": "narrator", "body": "夜を、眺めていた。" },
    { "cmd": "text", "char": "narrator", "body": "壁の向こうの怒鳴り声。男がどーだ女がこーだ——汚い音が等しく暗い空へ溶けていく。" },
    { "cmd": "text", "char": "narrator", "body": "どうして世界はこんなにも汚い音で満ちているのか。" },
    { "cmd": "text", "char": "narrator", "body": "耳を閉ざす。言葉を閉ざす。光を閉ざす。入江サキはそうやって生きてきた。" },
    { "cmd": "text", "char": "narrator", "body": "あと何年、心を固めていかなければならないのか——その悠久を思うたびに、人生が罰ゲームに見えた。" },
    { "cmd": "text", "char": "narrator", "body": "——「……。」" },
    { "cmd": "text", "char": "narrator", "body": "目の覚めるような気配が、すべての防壁をいともたやすく抜けて脳に響いた。" },
    { "cmd": "text", "char": "narrator", "body": "紅い瞳。強い瞳。燃える炎を人の形にしたような何か。" },
    { "cmd": "text", "char": "saki", "body": "（——こんな風に、いることもできるんだ）" },
    { "cmd": "text", "char": "narrator", "body": "今際の際の大発見に、心臓が跳ね上がった。" },
    { "cmd": "text", "char": "narrator", "body": "だから——泣いた。" },
    { "cmd": "text", "char": "narrator", "body": "わんわんと。盛大に。格好よくなんて、全然なく。" },
    { "cmd": "text", "char": "narrator", "body": "泣き続けた。泣き止まなかった。" },
    { "cmd": "text", "char": "narrator", "body": "見かねた天使に口を塞がれるまで——零れ続けた。" },
    { "cmd": "text", "char": "narrator", "body": "気づいたとき、死にたいという気持ちが——消えていた。" },
    { "cmd": "flag", "key": "CHAPTER00_COMPLETE", "value": "true" }
  ]
}
