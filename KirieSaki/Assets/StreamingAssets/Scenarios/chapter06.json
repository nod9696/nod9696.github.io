{
  "chapterId": "chapter06",
  "title": "第六章「後退の夜」",
  "commands": [
    { "cmd": "bgm", "id": "night_ambient", "fade": 2.0 },
    { "cmd": "bg", "id": "saki_room", "transition": "fade" },
    { "cmd": "text", "char": "narrator", "body": "夜。サキが帰ると——キリエがいなかった。" },
    { "cmd": "sprite", "char": "saki", "pose": "normal", "position": "center" },
    { "cmd": "text", "char": "saki", "body": "キリエ？……いない。" },
    { "cmd": "text", "char": "narrator", "body": "メモなし。連絡なし。ただ、いない。" },
    { "cmd": "text", "char": "saki", "body": "……まあ、すぐ帰ってくるか。" },
    { "cmd": "bgm", "id": "emotional_piano", "fade": 3.0 },
    { "cmd": "text", "char": "narrator", "body": "一時間、経った。" },
    { "cmd": "sprite", "char": "saki", "pose": "anxious", "position": "center" },
    { "cmd": "text", "char": "saki", "body": "……遅い。" },
    { "cmd": "text", "char": "narrator", "body": "二時間、経った。深夜を過ぎた。窓の外、街は静かになっていく。" },
    { "cmd": "text", "char": "saki", "body": "（なんで、こんなに——）" },
    { "cmd": "text", "char": "narrator", "body": "サキは気づいた。" },
    { "cmd": "text", "char": "narrator", "body": "思っていたより、不安だった。" },
    { "cmd": "text", "char": "narrator", "body": "思っていたより——依存していた。" },
    { "cmd": "text", "char": "saki", "body": "いつから、こうなったんだろ。いないと、変な感じがする。" },
    { "cmd": "text", "char": "narrator", "body": "それが何なのか。サキには名前がつけられなかった。" },
    { "cmd": "bg", "id": "apartment_window", "transition": "fade" },
    { "cmd": "text", "char": "narrator", "body": "夜明け前。窓の外が、白み始めた。" },
    { "cmd": "se", "id": "door_open" },
    { "cmd": "sprite", "char": "kirie", "pose": "normal", "position": "right" },
    { "cmd": "text", "char": "kirie", "body": "……戻った。" },
    { "cmd": "sprite", "char": "saki", "pose": "surprised", "position": "left" },
    { "cmd": "text", "char": "saki", "body": "今何時だと思ってんの。" },
    { "cmd": "text", "char": "kirie", "body": "夜明け前だ。" },
    { "cmd": "text", "char": "saki", "body": "どこ行ってたの。" },
    { "cmd": "text", "char": "kirie", "body": "外だ。" },
    { "cmd": "sprite", "char": "saki", "pose": "anxious", "position": "left" },
    { "cmd": "text", "char": "saki", "body": "それだけ？　何も言わないで出て行って——それだけ？" },
    { "cmd": "text", "char": "kirie", "body": "……問題があったか？" },
    { "cmd": "text", "char": "saki", "body": "あった！　なんで言わないで消えるの！" },
    { "cmd": "effect", "type": "shake", "intensity": 0.3, "duration": 0.5 },
    { "cmd": "text", "char": "narrator", "body": "キリエはサキを見た。" },
    { "cmd": "text", "char": "narrator", "body": "声が震えている。これが——怒り、というものか。" },
    { "cmd": "text", "char": "narrator", "body": "恐怖は知っている。痛みも、孤独も。変数として記録してきた。" },
    { "cmd": "text", "char": "narrator", "body": "しかしこれは——何だ。" },
    { "cmd": "text", "char": "kirie", "body": "……怒っている理由がわからない。" },
    { "cmd": "text", "char": "saki", "body": "一言も言わないで消えたら——私が心配するって思わなかった！？" },
    { "cmd": "text", "char": "kirie", "body": "……心配。" },
    { "cmd": "text", "char": "saki", "body": "そう！　した！　なんでかは私にもわからないけど——した！" },
    { "cmd": "text", "char": "kirie", "body": "……私が出ることは、お前に影響しないと思っていた。" },
    { "cmd": "text", "char": "saki", "body": "影響する。私には。" },
    { "cmd": "text", "char": "narrator", "body": "沈黙。" },
    { "cmd": "text", "char": "narrator", "body": "キリエはその言葉を反芻した。何度も。何度も。" },
    { "cmd": "text", "char": "narrator", "body": "影響する。私には——。" },
    { "cmd": "text", "char": "kirie", "body": "……次は、言う。" },
    { "cmd": "text", "char": "narrator", "body": "たった五文字。" },
    { "cmd": "sprite", "char": "saki", "pose": "normal", "position": "left" },
    { "cmd": "text", "char": "saki", "body": "……うん。それだけでいい。" },
    { "cmd": "text", "char": "narrator", "body": "でもサキには、十分だった。" },
    { "cmd": "text", "char": "narrator", "body": "後退のふりをした、前進の夜。" },
    { "cmd": "flag", "key": "CHAPTER06_COMPLETE", "value": "true" }
  ]
}
