{
  "chapterId": "chapter03",
  "title": "第三章「夜の街へ」",
  "commands": [
    { "cmd": "bgm", "id": "town_night", "fade": 2.0 },
    { "cmd": "bg", "id": "town_street", "transition": "fade" },
    { "cmd": "text", "char": "narrator", "body": "夜の街。初めての外出。" },
    { "cmd": "sprite", "char": "saki", "pose": "normal", "position": "left" },
    { "cmd": "sprite", "char": "kirie", "pose": "normal", "position": "right" },
    { "cmd": "text", "char": "saki", "body": "どう？外、久しぶりでしょ。" },
    { "cmd": "text", "char": "kirie", "body": "久しぶりではない。ただ——この密度は、想定外だ。" },
    { "cmd": "text", "char": "saki", "body": "これでも少ないほうだよ今日は。" },
    { "cmd": "text", "char": "kirie", "body": "全員、どこかへ向かっている。" },
    { "cmd": "text", "char": "saki", "body": "まあね。家とか、店とか。" },
    { "cmd": "text", "char": "kirie", "body": "目的があるから動く。そういうものか、人間とは。" },
    { "cmd": "text", "char": "saki", "body": "（哲学者みたいなこと言う……）キリエって、人をどう見てるの？" },
    { "cmd": "text", "char": "kirie", "body": "観察する。習慣だ。昔は獲物として見ていた。今は違う。" },
    { "cmd": "text", "char": "saki", "body": "今は？" },
    { "cmd": "text", "char": "kirie", "body": "ただ、見ている。" },
    { "cmd": "text", "char": "saki", "body": "（……それが一番怖い気がする）" },
    { "cmd": "text", "char": "narrator", "body": "路地の角。酔った男が前に立ちふさがった。" },
    { "cmd": "se", "id": "footsteps" },
    { "cmd": "text", "char": "saki", "body": "あ——" },
    { "cmd": "text", "char": "narrator", "body": "男がサキに絡みかけた瞬間——キリエが一歩、前へ出た。" },
    { "cmd": "sprite", "char": "kirie", "pose": "normal", "position": "center" },
    { "cmd": "text", "char": "narrator", "body": "無言。ただ、男の目を見た。" },
    { "cmd": "text", "char": "narrator", "body": "捕食者の目で。" },
    { "cmd": "text", "char": "narrator", "body": "男は何かを感じ取り——言葉を呑んで、足早に消えた。" },
    { "cmd": "sprite", "char": "kirie", "pose": "normal", "position": "right" },
    { "cmd": "sprite", "char": "saki", "pose": "surprised", "position": "left" },
    { "cmd": "text", "char": "saki", "body": "……何もしてないのに逃げた。" },
    { "cmd": "text", "char": "kirie", "body": "目だけで伝わる。致死的だと。" },
    { "cmd": "text", "char": "saki", "body": "けど——ありがとね。" },
    { "cmd": "text", "char": "kirie", "body": "礼は不要だ。" },
    { "cmd": "text", "char": "saki", "body": "（……素直じゃないのか、そもそも礼の概念がないのか）" },
    { "cmd": "bgm", "id": "night_ambient", "fade": 2.0 },
    { "cmd": "bg", "id": "convenience_store", "transition": "fade" },
    { "cmd": "text", "char": "narrator", "body": "コンビニ。キリエが入口で止まった。" },
    { "cmd": "text", "char": "kirie", "body": "……何だ、ここは。" },
    { "cmd": "sprite", "char": "saki", "pose": "smile", "position": "left" },
    { "cmd": "text", "char": "saki", "body": "コンビニ。知らないの？" },
    { "cmd": "text", "char": "kirie", "body": "この規模のものは、なかった。昔は。" },
    { "cmd": "text", "char": "saki", "body": "好きなもの選んでいいよ。なんか買ってあげる。" },
    { "cmd": "text", "char": "narrator", "body": "キリエは棚の間を歩いた。一度も迷わなかった。" },
    { "cmd": "text", "char": "narrator", "body": "飲み物のコーナーで止まる。一本、手に取る。" },
    { "cmd": "text", "char": "kirie", "body": "これだ。" },
    { "cmd": "text", "char": "saki", "body": "グレープファンタ……。なんで？" },
    { "cmd": "text", "char": "kirie", "body": "色が最も鮮やかだった。" },
    { "cmd": "text", "char": "saki", "body": "それだけ？" },
    { "cmd": "text", "char": "kirie", "body": "それだけだ。" },
    { "cmd": "text", "char": "saki", "body": "（……まあ、悪くない理由かもしれない）いいか。じゃあ買おっか。" },
    { "cmd": "bgm", "id": "saki_theme", "fade": 2.5 },
    { "cmd": "bg", "id": "river_bank", "transition": "fade" },
    { "cmd": "text", "char": "narrator", "body": "川沿い。二人並んで、水面を眺めた。" },
    { "cmd": "sprite", "char": "saki", "pose": "normal", "position": "left" },
    { "cmd": "sprite", "char": "kirie", "pose": "normal", "position": "right" },
    { "cmd": "text", "char": "narrator", "body": "キリエがグレープファンタを一口飲む。" },
    { "cmd": "text", "char": "kirie", "body": "……甘い。過剰に。" },
    { "cmd": "text", "char": "saki", "body": "そういうもんだよ。おいしい？" },
    { "cmd": "text", "char": "kirie", "body": "……わからない。" },
    { "cmd": "text", "char": "saki", "body": "ねえキリエ。聞いていい？" },
    { "cmd": "text", "char": "kirie", "body": "なにを。" },
    { "cmd": "text", "char": "saki", "body": "なんで、もう人の血を吸わないの？ずっと気になってた。" },
    { "cmd": "text", "char": "kirie", "body": "……気が向かない。" },
    { "cmd": "text", "char": "saki", "body": "気が向かない……って、それだけ？" },
    { "cmd": "text", "char": "kirie", "body": "そうだ。" },
    { "cmd": "text", "char": "saki", "body": "なんで気が向かないの？" },
    { "cmd": "text", "char": "kirie", "body": "……わからない。" },
    { "cmd": "text", "char": "narrator", "body": "川の水が、静かに流れ続けた。" },
    { "cmd": "text", "char": "narrator", "body": "キリエはグレープファンタを見つめた。サキはそれ以上、聞かなかった。" },
    { "cmd": "text", "char": "narrator", "body": "「わからない」が、今夜一番正直な言葉だった。" },
    { "cmd": "flag", "key": "CHAPTER03_COMPLETE", "value": "true" }
  ]
}
