    { "cmd": "text", "char": "hakushoku", "body": "……そんなことが——お前には——" },
    { "cmd": "text", "char": "kirie", "body": "五十万七千三十六回分の意志を、今ここで反転させる。" },
    { "cmd": "effect", "type": "flash", "color": "white", "duration": 0.3 },
    { "cmd": "text", "char": "saki", "body": "キリエ——！" },
