{
  "chapterId": "chapter05",
  "title": "第五章「先を越した何か」",
  "commands": [
    { "cmd": "bgm", "id": "town_day", "fade": 2.0 },
    { "cmd": "bg", "id": "saki_room", "transition": "fade" },
    { "cmd": "text", "char": "narrator", "body": "午後。唐突に、インターホンが鳴った。" },
    { "cmd": "text", "char": "narrator", "body": "サキは部屋の奥にいた。キリエがドアを開けた。当然のように。" },
    { "cmd": "se", "id": "door_open" },
    { "cmd": "sprite", "char": "kirie", "pose": "normal", "position": "center" },
    { "cmd": "sprite", "char": "suzumura", "pose": "surprised", "position": "left" },
    { "cmd": "text", "char": "narrator", "body": "鈴村、戦慄。" },
    { "cmd": "text", "char": "suzumura", "body": "……あ、えと。鈴村といいます。サキの、友達で——" },
    { "cmd": "text", "char": "kirie", "body": "知っている。入れ。" },
    { "cmd": "text", "char": "suzumura", "body": "え、あ、は、い……（知ってんの？）" },
    { "cmd": "text", "char": "suzumura", "body": "あなたは……？" },
    { "cmd": "text", "char": "kirie", "body": "逆真キリエ。ここにいる。" },
    { "cmd": "text", "char": "suzumura", "body": "サキと、どういう……関係、ですか。" },
    { "cmd": "text", "char": "kirie", "body": "同居している。" },
    { "cmd": "sprite", "char": "suzumura", "pose": "anxious", "position": "left" },
    { "cmd": "text", "char": "suzumura", "body": "……同居。（待って待って待って）" },
    { "cmd": "text", "char": "suzumura", "body": "サキは元気ですか。" },
    { "cmd": "text", "char": "kirie", "body": "元気の定義が曖昧だ。" },
    { "cmd": "text", "char": "suzumura", "body": "は？" },
    { "cmd": "text", "char": "kirie", "body": "身体的に問題はない。精神的状態については観測が難しい。今朝は食事をした。" },
    { "cmd": "sprite", "char": "suzumura", "pose": "surprised", "position": "left" },
    { "cmd": "text", "char": "suzumura", "body": "……（何この人）" },
    { "cmd": "sprite", "char": "saki", "pose": "surprised", "position": "right" },
    { "cmd": "text", "char": "saki", "body": "鈴村くん——！？ なんで来——" },
    { "cmd": "text", "char": "suzumura", "body": "サキ。学校来ないし、連絡もないし。心配したんだよ。" },
    { "cmd": "text", "char": "saki", "body": "あ、ごめん。大丈夫だよ。" },
    { "cmd": "text", "char": "suzumura", "body": "大丈夫に見えない。この人は——どこで知り合ったの。" },
    { "cmd": "text", "char": "kirie", "body": "屋上だ。" },
    { "cmd": "text", "char": "saki", "body": "キリエ。" },
    { "cmd": "text", "char": "kirie", "body": "サキが飛び降りようとしていた。私もそこにいた。それだけだ。" },
    { "cmd": "text", "char": "saki", "body": "キリエ！！" },
    { "cmd": "text", "char": "kirie", "body": "嘘をつく理由がない。" },
    { "cmd": "sprite", "char": "suzumura", "pose": "normal", "position": "left" },
    { "cmd": "text", "char": "narrator", "body": "鈴村が固まった。二秒。三秒。" },
    { "cmd": "text", "char": "suzumura", "body": "……サキ。ちょっとだけ、二人で話せる？" },
    { "cmd": "sprite_hide", "char": "kirie" },
    { "cmd": "text", "char": "narrator", "body": "キリエは無言で部屋の奥に退いた。いつもの速度で。何も感じていないように。" },
    { "cmd": "text", "char": "suzumura", "body": "（小声で）ほんとに大丈夫なの。あの人、なんか——怖い。" },
    { "cmd": "text", "char": "saki", "body": "怖くはない。変なのは本当だけど。" },
    { "cmd": "text", "char": "suzumura", "body": "変って次元じゃない気がするんだけど……。サキ、ちゃんとここにいるの？" },
    { "cmd": "text", "char": "saki", "body": "いるよ。私は今、ちゃんとここにいる。" },
    { "cmd": "text", "char": "suzumura", "body": "……何かあったらすぐ言って。すぐ来るから。" },
    { "cmd": "text", "char": "saki", "body": "うん。覚えてて。" },
    { "cmd": "se", "id": "door_open" },
    { "cmd": "sprite_hide", "char": "suzumura" },
    { "cmd": "text", "char": "narrator", "body": "ドアが閉まった。静寂が戻った。" },
    { "cmd": "sprite", "char": "kirie", "pose": "normal", "position": "center" },
    { "cmd": "sprite", "char": "saki", "pose": "normal", "position": "left" },
    { "cmd": "text", "char": "saki", "body": "ねえ。キリエ。" },
    { "cmd": "text", "char": "kirie", "body": "なんだ。" },
    { "cmd": "text", "char": "saki", "body": "あなた——鈴村くんを傷つけようとした？" },
    { "cmd": "text", "char": "kirie", "body": "いいえ。" },
    { "cmd": "text", "char": "saki", "body": "なんで？" },
    { "cmd": "text", "char": "narrator", "body": "沈黙。短い。でも確かに、あった。" },
    { "cmd": "text", "char": "kirie", "body": "……お前が、それを望まないから。" },
    { "cmd": "sprite", "char": "saki", "pose": "surprised", "position": "left" },
    { "cmd": "text", "char": "narrator", "body": "サキは何も言えなかった。" },
    { "cmd": "text", "char": "narrator", "body": "言葉より先に——何かが、来た。" },
    { "cmd": "text", "char": "saki", "body": "……そういうこと言うんだ、あなた。" },
    { "cmd": "text", "char": "kirie", "body": "……。" },
    { "cmd": "text", "char": "narrator", "body": "キリエは答えなかった。答える言葉を、まだ持っていなかった。" },
    { "cmd": "flag", "key": "CHAPTER05_COMPLETE", "value": "true" }
  ]
}
