{
  "chapterId": "chapter04",
  "title": "第四章「サキの部屋」",
  "commands": [
    { "cmd": "bgm", "id": "rainfall_ambient", "fade": 2.0 },
    { "cmd": "bg", "id": "saki_room", "transition": "fade" },
    { "cmd": "text", "char": "narrator", "body": "雨の夜。" },
    { "cmd": "text", "char": "narrator", "body": "窓を打つ水音だけが、部屋に満ちていた。" },
    { "cmd": "sprite", "char": "kirie", "pose": "normal", "position": "right" },
    { "cmd": "text", "char": "narrator", "body": "キリエはいつものように窓際にいた。サキは眠っていた。" },
    { "cmd": "text", "char": "narrator", "body": "深夜。サキの呼吸が、乱れた。" },
    { "cmd": "text", "char": "saki", "body": "……っ、や——" },
    { "cmd": "sprite", "char": "saki", "pose": "anxious", "position": "left" },
    { "cmd": "text", "char": "narrator", "body": "目が覚める。頬が濡れていた。夢を見ていた。" },
    { "cmd": "text", "char": "saki", "body": "はぁ……はぁ……。" },
    { "cmd": "text", "char": "kirie", "body": "目が覚めたか。" },
    { "cmd": "text", "char": "saki", "body": "……キリエ。起きてたの。" },
    { "cmd": "text", "char": "kirie", "body": "眠らない。" },
    { "cmd": "text", "char": "narrator", "body": "キリエはサキを見た。どうすべきか——データがなかった。" },
    { "cmd": "text", "char": "narrator", "body": "五十万七千三十六回死のうとして、それでも泣き方を知らなかった。" },
    { "cmd": "text", "char": "kirie", "body": "……。" },
    { "cmd": "text", "char": "saki", "body": "なんでもない。また寝る。" },
    { "cmd": "text", "char": "kirie", "body": "泣いている。" },
    { "cmd": "text", "char": "saki", "body": "わかってる。" },
    { "cmd": "text", "char": "kirie", "body": "……。" },
    { "cmd": "text", "char": "narrator", "body": "雨音だけが続いた。" },
    { "cmd": "text", "char": "narrator", "body": "長い沈黙。" },
    { "cmd": "text", "char": "narrator", "body": "やがて——キリエが立ち上がった。" },
    { "cmd": "text", "char": "narrator", "body": "ゆっくりと、サキのそばへ。床に、座った。言葉はなかった。" },
    { "cmd": "sprite", "char": "kirie", "pose": "normal", "position": "left" },
    { "cmd": "text", "char": "narrator", "body": "近づき方がわからない。でも——近づいた。" },
    { "cmd": "text", "char": "saki", "body": "（……なんで来るの。こんな顔、見せたくないのに）" },
    { "cmd": "text", "char": "narrator", "body": "サキはしばらく何も言わなかった。" },
    { "cmd": "text", "char": "narrator", "body": "それから——静かに、キリエの肩に頭を預けた。" },
    { "cmd": "text", "char": "kirie", "body": "……。" },
    { "cmd": "text", "char": "narrator", "body": "キリエは動かなかった。" },
    { "cmd": "text", "char": "narrator", "body": "動き方がわからなかった。" },
    { "cmd": "text", "char": "narrator", "body": "この感触が何を意味するのか——やはり、わからなかった。" },
    { "cmd": "text", "char": "narrator", "body": "それでも——離れなかった。" },
    { "cmd": "text", "char": "narrator", "body": "雨は、夜明け近くまで続いた。" },
    { "cmd": "bgm", "id": "morning_ambient", "fade": 3.0 },
    { "cmd": "bg", "id": "saki_room_morning", "transition": "fade" },
    { "cmd": "text", "char": "narrator", "body": "翌朝。サキはいつものように起き上がり、何事もなかった顔をした。" },
    { "cmd": "sprite", "char": "saki", "pose": "normal", "position": "left" },
    { "cmd": "sprite", "char": "kirie", "pose": "normal", "position": "right" },
    { "cmd": "text", "char": "saki", "body": "おはよ。今日も晴れてるね。" },
    { "cmd": "text", "char": "kirie", "body": "昨夜のこと——" },
    { "cmd": "sprite", "char": "saki", "pose": "anxious", "position": "left" },
    { "cmd": "text", "char": "saki", "body": "忘れて。" },
    { "cmd": "text", "char": "kirie", "body": "……わかった。" },
    { "cmd": "text", "char": "narrator", "body": "キリエはそう言った。" },
    { "cmd": "text", "char": "narrator", "body": "忘れなかった。" },
    { "cmd": "sprite_hide", "char": "saki" },
    { "cmd": "text", "char": "narrator", "body": "一日じゅう、考えた。あの重さのことを。サキの頭が触れていた——あの温度のことを。" },
    { "cmd": "text", "char": "narrator", "body": "それが何なのか、名前を持っていなかった。" },
    { "cmd": "text", "char": "narrator", "body": "でも確かに——あった。" },
    { "cmd": "text", "char": "kirie", "body": "……許容できる、重さだった。" },
    { "cmd": "flag", "key": "CHAPTER04_COMPLETE", "value": "true" }
  ]
}
