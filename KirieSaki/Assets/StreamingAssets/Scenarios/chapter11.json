{
  "chapterId": "chapter11",
  "title": "「白が満ちる夜に」",
  "commands": [
    { "cmd": "bgm", "id": "night_ambient", "fade": 2.0 },
    { "cmd": "bg", "id": "saki_room", "transition": "fade" },
    { "cmd": "text", "char": "narrator", "body": "夜。キリエがいない。" },
    { "cmd": "sprite", "char": "saki", "pose": "normal", "position": "center" },
    { "cmd": "text", "char": "narrator", "body": "サキはひとりだった。" },
    { "cmd": "bgm", "id": "wilderness_night", "fade": 3.0 },
    { "cmd": "text", "char": "narrator", "body": "最初は、静けさだけだった。" },
    { "cmd": "text", "char": "narrator", "body": "少しずつ、空気が変わっていった。重くなる。内側から。" },
    { "cmd": "text", "char": "saki", "body": "……なに、これ。" },
    { "cmd": "text", "char": "narrator", "body": "思考が、自分のものでなくなっていく。" },
    { "cmd": "text", "char": "hakushoku", "body": "……知っているだろう。この感覚を。" },
    { "cmd": "sprite", "char": "saki", "pose": "anxious", "position": "center" },
    { "cmd": "text", "char": "saki", "body": "誰——？" },
    { "cmd": "text", "char": "hakushoku", "body": "お前の中にずっといた。お前が生まれる前から。" },
    { "cmd": "text", "char": "saki", "body": "（ちがう、これは——ちがう、ちがう——）" },
    { "cmd": "text", "char": "narrator", "body": "足が動いていた。廊下。扉。階段。" },
    { "cmd": "text", "char": "narrator", "body": "気がついたら、外にいた。" },
    { "cmd": "se", "id": "door_open" },
    { "cmd": "bg", "id": "rooftop", "transition": "fade" },
    { "cmd": "text", "char": "narrator", "body": "屋上。風が吹いていた。街の光が遠い。縁が——近い。" },
    { "cmd": "sprite", "char": "saki", "pose": "anxious", "position": "center" },
    { "cmd": "text", "char": "hakushoku", "body": "楽になれる。お前は知っている。キリエもそれを知っていた。五十万回、ここに来た。" },
    { "cmd": "text", "char": "saki", "body": "……やめて。" },
    { "cmd": "text", "char": "hakushoku", "body": "やめたくない。お前もやめたくない。お前の痛みはずっとここにある。終わりにしていい。" },
    { "cmd": "text", "char": "saki", "body": "……キリエ。" },
    { "cmd": "text", "char": "narrator", "body": "声にならなかった。ただ——名前だけが、口をついて出た。" },
    { "cmd": "se", "id": "footsteps" },
    { "cmd": "effect", "type": "shake", "intensity": 0.4, "duration": 0.5 },
    { "cmd": "sprite", "char": "kirie", "pose": "normal", "position": "left" },
    { "cmd": "text", "char": "kirie", "body": "サキ。" },
    { "cmd": "sprite", "char": "saki", "pose": "surprised", "position": "right" },
    { "cmd": "text", "char": "saki", "body": "キリエ——！" },
    { "cmd": "bgm", "id": "kirie_hunt", "fade": 1.0 },
    { "cmd": "text", "char": "narrator", "body": "キリエは屋上に立っていた。その目は、サキではなく——その背後の、空気を見ていた。" },
    { "cmd": "text", "char": "kirie", "body": "……いたか。" },
    { "cmd": "text", "char": "hakushoku", "body": "久しいな、キリエ。ずっとそばにいた。お前が気づかなかっただけだ。" },
    { "cmd": "text", "char": "kirie", "body": "知っている。" },
    { "cmd": "text", "char": "hakushoku", "body": "お前と私は同じだ。お前が死を望んだ、その意志そのものが私だ。切り離せない。" },
    { "cmd": "text", "char": "kirie", "body": "……そうだった。" },
    { "cmd": "text", "char": "hakushoku", "body": "いつから、と思う？ お前は変わったつもりでいる。だが——お前が存在する限り、私も消えない。この娘もそうだ。お前のそばにいる限り、私に近づいていく。" },
    { "cmd": "effect", "type": "shake", "intensity": 0.7, "duration": 1.0 },
    { "cmd": "text", "char": "kirie", "body": "……違う。" },
    { "cmd": "text", "char": "hakushoku", "body": "違わない。お前は——" },
    { "cmd": "text", "char": "kirie", "body": "違う。" },
    { "cmd": "text", "char": "narrator", "body": "抑揚がない。だが——空気が変わった。" },
    { "cmd": "text", "char": "hakushoku", "body": "……いつから、だ。いつからそんなことを言う。" },
    { "cmd": "text", "char": "narrator", "body": "長い沈黙。" },
    { "cmd": "text", "char": "kirie", "body": "……わからない。ただ今は、違う。" },
    { "cmd": "text", "char": "hakushoku", "body": "お前は変われない——" },
    { "cmd": "text", "char": "kirie", "body": "去れ。" },
    { "cmd": "effect", "type": "flash", "color": "white", "duration": 0.5 },
    { "cmd": "effect", "type": "shake", "intensity": 0.7, "duration": 1.0 },
    { "cmd": "text", "char": "narrator", "body": "白い光が屋上を満たした。一瞬。" },
    { "cmd": "bgm", "id": "night_ambient", "fade": 2.0 },
    { "cmd": "text", "char": "narrator", "body": "静かになった。" },
    { "cmd": "text", "char": "narrator", "body": "重さが消えた。引力が消えた。" },
    { "cmd": "sprite", "char": "saki", "pose": "anxious", "position": "right" },
    { "cmd": "text", "char": "narrator", "body": "サキの膝から力が抜けた。崩れていく。" },
    { "cmd": "sprite", "char": "kirie", "pose": "normal", "position": "left" },
    { "cmd": "text", "char": "narrator", "body": "キリエが間に合った。受け止めた。無言のまま。" },
    { "cmd": "text", "char": "saki", "body": "……キリエ。" },
    { "cmd": "text", "char": "kirie", "body": "ここにいる。" },
    { "cmd": "text", "char": "saki", "body": "私、なんで屋上に……気がついたら——" },
    { "cmd": "text", "char": "kirie", "body": "お前のせいではない。" },
    { "cmd": "text", "char": "narrator", "body": "キリエはサキを離さなかった。" },
    { "cmd": "text", "char": "narrator", "body": "風が吹いている。遠くでサイレンの音。" },
    { "cmd": "se", "id": "siren" },
    { "cmd": "text", "char": "kirie", "body": "……中に入ろう。" },
    { "cmd": "flag", "key": "FLAG_HAKUSHOKU_DEFEATED", "value": "true" },
    { "cmd": "flag", "key": "CHAPTER11_COMPLETE", "value": "true" }
  ]
}
