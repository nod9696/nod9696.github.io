{
  "chapterId": "chapter02",
  "title": "第二章「昼間のキリエ」",
  "commands": [
    { "cmd": "bgm", "id": "morning_ambient", "fade": 2.0 },
    { "cmd": "bg", "id": "saki_room_morning", "transition": "fade" },
    { "cmd": "text", "char": "narrator", "body": "数日が経った。" },
    { "cmd": "text", "char": "narrator", "body": "逆真キリエは依然として、入江サキの部屋にいた。" },
    { "cmd": "sprite", "char": "kirie", "pose": "normal", "position": "center" },
    { "cmd": "text", "char": "narrator", "body": "朝。カーテンの隙間から光が差し込む。" },
    { "cmd": "text", "char": "kirie", "body": "……光だ。" },
    { "cmd": "text", "char": "narrator", "body": "指先でカーテンをわずかに開ける。光を受ける。" },
    { "cmd": "text", "char": "kirie", "body": "灼けない。" },
    { "cmd": "text", "char": "kirie", "body": "不快ではある。" },
    { "cmd": "sprite", "char": "saki", "pose": "normal", "position": "left" },
    { "cmd": "text", "char": "saki", "body": "おはよ——あ、カーテン開けないで、眩しい。" },
    { "cmd": "text", "char": "kirie", "body": "光は致死的でなかった。" },
    { "cmd": "text", "char": "saki", "body": "（毎回それ言う……）そりゃよかったね。学校行ってくる。バイトもあるし、夜になるまで帰れないかも。" },
    { "cmd": "text", "char": "kirie", "body": "記憶した。" },
    { "cmd": "text", "char": "saki", "body": "冷蔵庫に食べ物あるから。キリエって食べ物食べられる？" },
    { "cmd": "text", "char": "kirie", "body": "食べられる。死なないだけで、味はわかる。" },
    { "cmd": "text", "char": "saki", "body": "……じゃあ適当に食べといて。いってきます。" },
    { "cmd": "se", "id": "door_open" },
    { "cmd": "sprite_hide", "char": "saki" },
    { "cmd": "text", "char": "narrator", "body": "一人になった。" },
    { "cmd": "text", "char": "narrator", "body": "静寂。誰かの生活の痕跡だけが残された部屋。" },
    { "cmd": "text", "char": "narrator", "body": "キリエは部屋を見回した。雑貨。本。折りたたまれた紙切れ。" },
    { "cmd": "text", "char": "narrator", "body": "——そして、棚の隅に置かれた一冊の厚いスケッチブック。" },
    { "cmd": "text", "char": "kirie", "body": "……。" },
    { "cmd": "text", "char": "narrator", "body": "表紙に何も書かれていない。キリエは手に取り、開いた。" },
    { "cmd": "text", "char": "narrator", "body": "縄で縛られた少女。高所から落下する人影。暗い水の中で目を閉じた顔。" },
    { "cmd": "text", "char": "narrator", "body": "ページをめくる。また暗い絵。また落下。また縛られた何か。" },
    { "cmd": "text", "char": "narrator", "body": "キリエは判断しなかった。ただ、見た。" },
    { "cmd": "text", "char": "kirie", "body": "これを描いた手は——震えていたのか。それとも、落ち着いていたのか。" },
    { "cmd": "text", "char": "narrator", "body": "描けないことを、描いている。" },
    { "cmd": "text", "char": "narrator", "body": "キリエはスケッチブックを元の位置に戻し、窓際に座った。日光は相変わらず不快だった。" },
    { "cmd": "text", "char": "narrator", "body": "それでも——目を閉じなかった。" },
    { "cmd": "bgm", "id": "emotional_piano", "fade": 3.0 },
    { "cmd": "bg", "id": "saki_room", "transition": "fade" },
    { "cmd": "text", "char": "narrator", "body": "夜。玄関が開く。" },
    { "cmd": "se", "id": "door_open" },
    { "cmd": "sprite", "char": "saki", "pose": "normal", "position": "left" },
    { "cmd": "text", "char": "saki", "body": "ただいまー。電気つけてないじゃん。暗くない？" },
    { "cmd": "text", "char": "kirie", "body": "暗くない。見える。" },
    { "cmd": "text", "char": "saki", "body": "あー、そっか。吸血鬼か。" },
    { "cmd": "text", "char": "narrator", "body": "鞄を置き——サキの視線が棚へ流れた。スケッチブックの位置が、わずかに違った。" },
    { "cmd": "sprite", "char": "saki", "pose": "anxious", "position": "left" },
    { "cmd": "text", "char": "saki", "body": "……キリエ。あのスケッチブック——" },
    { "cmd": "text", "char": "kirie", "body": "見た。" },
    { "cmd": "text", "char": "saki", "body": "は……っ。なんで勝手に——あれは、人に見せるものじゃ——" },
    { "cmd": "text", "char": "kirie", "body": "怒っているか？" },
    { "cmd": "text", "char": "saki", "body": "怒ってる！当たり前じゃん！" },
    { "cmd": "sprite", "char": "kirie", "pose": "normal", "position": "center" },
    { "cmd": "text", "char": "kirie", "body": "お前は——言えないことを、描く。" },
    { "cmd": "sprite", "char": "saki", "pose": "surprised", "position": "left" },
    { "cmd": "text", "char": "saki", "body": "……え。" },
    { "cmd": "text", "char": "kirie", "body": "言葉にできないものを、線にする。それだけだ。" },
    { "cmd": "text", "char": "saki", "body": "……。" },
    { "cmd": "text", "char": "narrator", "body": "怒っているのか、泣きそうなのか——キリエには判断できなかった。" },
    { "cmd": "text", "char": "saki", "body": "……気持ち悪いくらい、正確だね。" },
    { "cmd": "text", "char": "kirie", "body": "そうか。" },
    { "cmd": "text", "char": "narrator", "body": "それ以上、どちらも何も言わなかった。" },
    { "cmd": "flag", "key": "FLAG_SKETCHBOOK_FOUND", "value": "true" },
    { "cmd": "flag", "key": "CHAPTER02_COMPLETE", "value": "true" }
  ]
}
