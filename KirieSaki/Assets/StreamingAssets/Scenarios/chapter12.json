{
  "chapterId": "chapter12",
  "title": "第十二章「人間が最初に泣いた夜」",
  "commands": [
    { "cmd": "bgm", "id": "emotional_piano", "fade": 3.0 },
    { "cmd": "bg", "id": "saki_room", "transition": "fade" },
    { "cmd": "sprite", "char": "saki", "pose": "anxious", "position": "right" },
    { "cmd": "sprite", "char": "kirie", "pose": "normal", "position": "left" },
    { "cmd": "text", "char": "narrator", "body": "屋上から戻ってきた。" },
    { "cmd": "text", "char": "narrator", "body": "誰も話さなかった。しばらく。" },
    { "cmd": "text", "char": "saki", "body": "……ねえ。" },
    { "cmd": "text", "char": "kirie", "body": "何か。" },
    { "cmd": "text", "char": "saki", "body": "キリエって、何なの。本当に。" },
    { "cmd": "text", "char": "narrator", "body": "いつもより、長い沈黙。" },
    { "cmd": "text", "char": "kirie", "body": "……話したことがなかった。" },
    { "cmd": "text", "char": "saki", "body": "うん。" },
    { "cmd": "text", "char": "kirie", "body": "話す必要がなかった。話す相手もいなかった。" },
    { "cmd": "text", "char": "saki", "body": "今は、話して。" },
    { "cmd": "sprite", "char": "kirie", "pose": "soliloquy", "position": "left" },
    { "cmd": "text", "char": "kirie", "body": "……私は、死を望んだ最初の人間の、残滓だ。" },
    { "cmd": "text", "char": "saki", "body": "残滓？" },
    { "cmd": "text", "char": "narrator", "body": "言葉の重さが、空気を変えた。" },
    { "cmd": "text", "char": "kirie", "body": "人類がまだ若かった頃——正確な時代は、わからない。一人の人間が、死を望んだ。誰もそんなことを考えたことがなかった時代に。強く、強く。" },
    { "cmd": "text", "char": "kirie", "body": "その感情は——消えなかった。強すぎたのか。最初だったから特別だったのか。感情そのものが、形を持った。それが私だ。" },
    { "cmd": "text", "char": "saki", "body": "……感情が、存在になった？" },
    { "cmd": "text", "char": "kirie", "body": "身体がある。人間と同じ形の。ただし、死なない。死のうとするたびに戻ってくる。五十万七千三十六回。" },
    { "cmd": "text", "char": "saki", "body": "それって——死ねたら、感情が消える、ってこと？" },
    { "cmd": "text", "char": "kirie", "body": "そう考えていた。死のうとする意志を消せば、私も消える。それが目的だった。" },
    { "cmd": "text", "char": "saki", "body": "……五十万回も、ずっとそれを。" },
    { "cmd": "text", "char": "kirie", "body": "失敗し続けた。毎回戻ってきた。だから続けた。それだけだ。" },
    { "cmd": "bgm", "id": "rainfall_ambient", "fade": 3.0 },
    { "cmd": "text", "char": "saki", "body": "……白蝕って、なんなの。あの白いやつ。" },
    { "cmd": "text", "char": "kirie", "body": "私が五十万七千三十六回積み重ねた意志の、外に溢れた部分だ。死のうとするたびに、少しずつ漏れ出た。それが集まってできた。" },
    { "cmd": "sprite", "char": "saki", "pose": "normal", "position": "right" },
    { "cmd": "text", "char": "saki", "body": "……それが私に——。" },
    { "cmd": "text", "char": "kirie", "body": "お前は元々、死を引き寄せやすい。理由はわからない。白蝕はそういう人間を好む。私のそばにいたせいで、近くにいた。" },
    { "cmd": "text", "char": "saki", "body": "キリエのせいじゃない。" },
    { "cmd": "text", "char": "kirie", "body": "……そうとも言い切れない。" },
    { "cmd": "text", "char": "saki", "body": "消えたかったの？　ずっと。" },
    { "cmd": "text", "char": "narrator", "body": "沈黙。" },
    { "cmd": "sprite", "char": "kirie", "pose": "soliloquy", "position": "left" },
    { "cmd": "text", "char": "kirie", "body": "……そうだった。" },
    { "cmd": "text", "char": "saki", "body": "今は？" },
    { "cmd": "text", "char": "narrator", "body": "沈黙。" },
    { "cmd": "text", "char": "kirie", "body": "……今は、違う。" },
    { "cmd": "sprite", "char": "saki", "pose": "anxious", "position": "right" },
    { "cmd": "text", "char": "saki", "body": "……じゃあ。じゃあ、やめて。" },
    { "cmd": "text", "char": "kirie", "body": "？" },
    { "cmd": "text", "char": "saki", "body": "死のうとするの。もうやめて。ずっと言いたかった。でも言えなかった。今言う——キリエに、死んでほしくない。" },
    { "cmd": "text", "char": "narrator", "body": "長い沈黙。" },
    { "cmd": "sprite", "char": "kirie", "pose": "surprised", "position": "left" },
    { "cmd": "text", "char": "kirie", "body": "……そう言った人間は。" },
    { "cmd": "text", "char": "narrator", "body": "沈黙。" },
    { "cmd": "text", "char": "kirie", "body": "……お前が最初だ。" },
    { "cmd": "text", "char": "narrator", "body": "サキは何か言おうとして、やめた。" },
    { "cmd": "text", "char": "narrator", "body": "キリエはまっすぐ前を見ていた。" },
    { "cmd": "bgm", "id": "emotional_piano", "fade": 2.0 },
    { "cmd": "text", "char": "narrator", "body": "その顔に、名前はなかった。" },
    { "cmd": "sprite", "char": "kirie", "pose": "normal", "position": "left" },
    { "cmd": "text", "char": "kirie", "body": "五十万七千三十六回の間。一人もいなかった。" },
    { "cmd": "text", "char": "saki", "body": "……うん。" },
    { "cmd": "text", "char": "kirie", "body": "……記憶した。お前の言葉を。" },
    { "cmd": "text", "char": "saki", "body": "覚えてて。" },
    { "cmd": "text", "char": "narrator", "body": "夜が続く。雨の音がする。" },
    { "cmd": "flag", "key": "CHAPTER12_COMPLETE", "value": "true" }
  ]
}
