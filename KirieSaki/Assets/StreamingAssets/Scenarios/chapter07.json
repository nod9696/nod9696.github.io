{
  "chapterId": "chapter07",
  "title": "第七章「川の名前」",
  "commands": [
    { "cmd": "bgm", "id": "saki_theme", "fade": 2.5 },
    { "cmd": "bg", "id": "river_bank", "transition": "fade" },
    { "cmd": "text", "char": "narrator", "body": "夜の川沿い。第三章と同じ場所。水の音は変わらない。人だけが、変わる。" },
    { "cmd": "sprite", "char": "saki", "pose": "normal", "position": "left" },
    { "cmd": "sprite", "char": "kirie", "pose": "normal", "position": "right" },
    { "cmd": "text", "char": "saki", "body": "またここ来たね。" },
    { "cmd": "text", "char": "kirie", "body": "川は変わらない。" },
    { "cmd": "text", "char": "saki", "body": "そうだね。……ねえ、聞いてもいい？" },
    { "cmd": "text", "char": "kirie", "body": "なにを。" },
    { "cmd": "text", "char": "saki", "body": "キリエって、何歳なの。" },
    { "cmd": "text", "char": "kirie", "body": "……数えるのをやめた。" },
    { "cmd": "text", "char": "saki", "body": "やめた、って——いつ？" },
    { "cmd": "text", "char": "kirie", "body": "数百年前だ。" },
    { "cmd": "text", "char": "saki", "body": "……。（すごい、って言葉しか出てこない）" },
    { "cmd": "text", "char": "saki", "body": "どこから来たの？" },
    { "cmd": "text", "char": "kirie", "body": "覚えていない。どこにもいた。どこにもいなかった。" },
    { "cmd": "text", "char": "saki", "body": "故郷は？" },
    { "cmd": "text", "char": "kirie", "body": "名前は記憶している。顔は消えた。場所も消えた。" },
    { "cmd": "text", "char": "saki", "body": "……長すぎると、消えちゃうんだね。" },
    { "cmd": "text", "char": "kirie", "body": "大半は消える。残るのは輪郭だけだ。" },
    { "cmd": "text", "char": "saki", "body": "じゃあ何を覚えてるの。今でも。" },
    { "cmd": "text", "char": "kirie", "body": "……川の名前。" },
    { "cmd": "text", "char": "saki", "body": "川の名前？" },
    { "cmd": "text", "char": "kirie", "body": "夜ごと、別の川を飛んだ。名前を空で暗唱した。することが、それしかなかったから。" },
    { "cmd": "bgm", "id": "emotional_piano", "fade": 3.0 },
    { "cmd": "text", "char": "saki", "body": "……なんか、寂しいね。" },
    { "cmd": "text", "char": "kirie", "body": "寂しいとは思わなかった。意味が、わからなかったから。" },
    { "cmd": "text", "char": "saki", "body": "今は？" },
    { "cmd": "text", "char": "kirie", "body": "……少し、わかる。" },
    { "cmd": "text", "char": "saki", "body": "ねえ。どこかに——ずっといたいって思ったこと、あった？" },
    { "cmd": "text", "char": "narrator", "body": "長い沈黙。水音だけが続く。キリエは川面を見た。" },
    { "cmd": "text", "char": "narrator", "body": "何十年分か、何百年分か——それだけの時間が、答えの前に横たわっていた。" },
    { "cmd": "text", "char": "kirie", "body": "……なかった。" },
    { "cmd": "text", "char": "saki", "body": "……そっか。" },
    { "cmd": "text", "char": "kirie", "body": "最近までは。" },
    { "cmd": "sprite", "char": "saki", "pose": "surprised", "position": "left" },
    { "cmd": "text", "char": "narrator", "body": "サキは何も聞かなかった。" },
    { "cmd": "text", "char": "narrator", "body": "それ以上聞いたら——何かが壊れる気がした。" },
    { "cmd": "sprite", "char": "saki", "pose": "normal", "position": "left" },
    { "cmd": "text", "char": "narrator", "body": "やがて、ぽつりと言った。自分だけが知る名前を。" },
    { "cmd": "text", "char": "saki", "body": "この川、私ずっと『ぬるかわ』って呼んでた。温い川、って書いて。名前じゃないけど。" },
    { "cmd": "text", "char": "kirie", "body": "……ぬるかわ。" },
    { "cmd": "text", "char": "narrator", "body": "キリエがその名を繰り返した。" },
    { "cmd": "text", "char": "narrator", "body": "古い器に注ぐように——静かに、確かに、響いた。" },
    { "cmd": "text", "char": "saki", "body": "……なんか違う感じがする。キリエが言うと。" },
    { "cmd": "text", "char": "kirie", "body": "記憶した。" },
    { "cmd": "text", "char": "narrator", "body": "今夜だけ、この川は別の川になった。" },
    { "cmd": "text", "char": "narrator", "body": "サキの名前で呼ばれた川が。" },
    { "cmd": "text", "char": "narrator", "body": "川は流れ続けた。二人はそこにいた。それだけで——十分だった。" },
    { "cmd": "flag", "key": "CHAPTER07_COMPLETE", "value": "true" }
  ]
}
