{
  "chapterId": "chapter10",
  "title": "独立章「夜の数え方」",
  "commands": [
    { "cmd": "bgm", "id": "night_ambient", "fade": 3.0 },
    { "cmd": "bg", "id": "apartment_window", "transition": "fade" },
    { "cmd": "text", "char": "narrator", "body": "深夜。" },
    { "cmd": "text", "char": "narrator", "body": "サキは眠っている。" },
    { "cmd": "sprite", "char": "kirie", "pose": "soliloquy", "position": "center" },
    { "cmd": "text", "char": "narrator", "body": "窓際に、キリエ。街灯が遠い。風も、ない。" },
    { "cmd": "bgm", "id": "emotional_piano", "fade": 3.0 },
    { "cmd": "text", "char": "narrator", "body": "数は嘘をつかない。数えられたものは、確かにあった。それだけでいい。" },
    { "cmd": "text", "char": "kirie", "body": "五十万七千三十六。" },
    { "cmd": "text", "char": "narrator", "body": "死のうとした回数。正確に。一度も忘れない。" },
    { "cmd": "text", "char": "kirie", "body": "渡った川の名前——数えるのをやめた。多すぎた。川が変わるより、名前が変わる方が速かった。" },
    { "cmd": "text", "char": "kirie", "body": "燃えた都市の数——記憶していない。灰になると、どこも同じ形をする。" },
    { "cmd": "text", "char": "kirie", "body": "忘れた名前の数——数えられない。忘れたから。" },
    { "cmd": "text", "char": "narrator", "body": "数えられないものは、消えたものだ。ずっとそう思ってきた。" },
    { "cmd": "text", "char": "narrator", "body": "では。新しい数を数えてみる。" },
    { "cmd": "text", "char": "kirie", "body": "サキが笑った回数——わからない。" },
    { "cmd": "text", "char": "narrator", "body": "途中で、数えるのをやめていた。" },
    { "cmd": "text", "char": "kirie", "body": "……初めてだ。数え損なったのは。" },
    { "cmd": "text", "char": "narrator", "body": "いつからだったか。公園で子供を見ていたときか。あるいはアイスを交換されたときか。正確にはわからない。気がついたら、数えていなかった。" },
    { "cmd": "text", "char": "narrator", "body": "——初めて、数えるのを見失った。" },
    { "cmd": "text", "char": "kirie", "body": "一緒に飲んだコーヒー——四十七杯。これは知っている。" },
    { "cmd": "text", "char": "kirie", "body": "砂糖——三杯。これも正確だ。" },
    { "cmd": "text", "char": "narrator", "body": "だが。この数字が何を意味するのか、わからない。" },
    { "cmd": "text", "char": "kirie", "body": "四十七杯。三杯。数えられなくなった笑顔。" },
    { "cmd": "text", "char": "kirie", "body": "……これは、何の算術だ。" },
    { "cmd": "bg", "id": "saki_room", "transition": "fade" },
    { "cmd": "text", "char": "narrator", "body": "キリエは立ち上がった。サキの部屋の入り口。扉越しに、眠っている気配。" },
    { "cmd": "text", "char": "narrator", "body": "呼吸している。規則正しく。温かそうに。" },
    { "cmd": "sprite", "char": "kirie", "pose": "soliloquy", "position": "center" },
    { "cmd": "text", "char": "narrator", "body": "五十万七千三十六回のうち、一度でも成功していたなら——この部屋はなかった。四十七杯のコーヒーも。数えられなくなった笑顔も。" },
    { "cmd": "text", "char": "kirie", "body": "……変数が、増えた。" },
    { "cmd": "text", "char": "narrator", "body": "その言葉を使ったのは、いつ以来だろう。" },
    { "cmd": "text", "char": "narrator", "body": "キリエはそっと扉を閉めた。窓際に戻った。夜が続く。" },
    { "cmd": "text", "char": "kirie", "body": "明日。" },
    { "cmd": "text", "char": "narrator", "body": "明日、という言葉が浮かんだ。" },
    { "cmd": "text", "char": "narrator", "body": "五十万七千三十六回、明日はカウントダウンだった。明日また試みる。明日こそ終わる。そういう意味だった。" },
    { "cmd": "text", "char": "kirie", "body": "……明日、がある。" },
    { "cmd": "text", "char": "narrator", "body": "今夜、その言葉は違う意味を持った。" },
    { "cmd": "text", "char": "narrator", "body": "ただ——明日が、ある。カウントダウンじゃない、初めての「明日」。" },
    { "cmd": "text", "char": "kirie", "body": "この算術の答えは、まだわからない。" },
    { "cmd": "text", "char": "kirie", "body": "……検証している。初めて。" },
    { "cmd": "text", "char": "narrator", "body": "街の灯りが揺れている。夜が、静かに続く。" },
    { "cmd": "flag", "key": "CHAPTER10_COMPLETE", "value": "true" }
  ]
}
