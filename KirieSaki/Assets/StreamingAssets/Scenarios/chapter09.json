{
  "chapterId": "chapter09",
  "title": "第九章「街の昼間」",
  "commands": [
    { "cmd": "bgm", "id": "morning_ambient", "fade": 2.0 },
    { "cmd": "bg", "id": "saki_room_morning", "transition": "fade" },
    { "cmd": "sprite", "char": "saki", "pose": "smile", "position": "right" },
    { "cmd": "sprite", "char": "kirie", "pose": "normal", "position": "left" },
    { "cmd": "text", "char": "saki", "body": "今日休みだから——外出ない？ 昼間に。" },
    { "cmd": "text", "char": "kirie", "body": "昼間。" },
    { "cmd": "text", "char": "saki", "body": "そ。帽子とかサングラスとか、ちゃんと対策すれば平気でしょ。" },
    { "cmd": "text", "char": "kirie", "body": "……試したことはない。" },
    { "cmd": "text", "char": "saki", "body": "じゃあ試してみよ。" },
    { "cmd": "bgm", "id": "town_day", "fade": 2.0 },
    { "cmd": "bg", "id": "town_street", "transition": "fade" },
    { "cmd": "text", "char": "narrator", "body": "キリエが現れた。帽子、サングラス、完全武装。" },
    { "cmd": "text", "char": "narrator", "body": "サキはしばらく何も言わなかった。" },
    { "cmd": "sprite", "char": "kirie", "pose": "normal", "position": "left" },
    { "cmd": "sprite", "char": "saki", "pose": "smile", "position": "right" },
    { "cmd": "text", "char": "saki", "body": "……似合ってる。" },
    { "cmd": "text", "char": "kirie", "body": "機能していればよい。" },
    { "cmd": "text", "char": "saki", "body": "機能もしてるし似合ってる。行こ。" },
    { "cmd": "text", "char": "narrator", "body": "昼間の街は、音で満ちていた。" },
    { "cmd": "text", "char": "narrator", "body": "車。人。どこかの店から流れてくる音楽。子供の笑い声。" },
    { "cmd": "sprite", "char": "kirie", "pose": "anxious", "position": "left" },
    { "cmd": "text", "char": "kirie", "body": "……多い。" },
    { "cmd": "text", "char": "saki", "body": "え？" },
    { "cmd": "text", "char": "kirie", "body": "情報が多い。夜と異なる。" },
    { "cmd": "sprite", "char": "saki", "pose": "normal", "position": "right" },
    { "cmd": "text", "char": "saki", "body": "あー、夜ってわりと静かだもんね。大丈夫？" },
    { "cmd": "text", "char": "kirie", "body": "問題ない。ただ——多い。" },
    { "cmd": "text", "char": "narrator", "body": "サキがキリエのペースに合わせた。ゆっくりと、歩いた。" },
    { "cmd": "bg", "id": "park", "transition": "fade" },
    { "cmd": "bgm", "id": "saki_theme", "fade": 2.0 },
    { "cmd": "text", "char": "narrator", "body": "公園。砂場で遊ぶ子、ブランコを漕ぐ子、走り回る子。" },
    { "cmd": "sprite", "char": "kirie", "pose": "normal", "position": "left" },
    { "cmd": "sprite", "char": "saki", "pose": "normal", "position": "right" },
    { "cmd": "text", "char": "narrator", "body": "キリエは立ったまま、子供たちを見ていた。その表情は、読めなかった。" },
    { "cmd": "text", "char": "saki", "body": "ねえ、何考えてるの。" },
    { "cmd": "text", "char": "kirie", "body": "子供だったことがない、と考えていた。" },
    { "cmd": "text", "char": "saki", "body": "……生まれてないの？" },
    { "cmd": "text", "char": "kirie", "body": "ある日、存在していた。子供の段階は——なかった。" },
    { "cmd": "text", "char": "saki", "body": "……そっか。" },
    { "cmd": "text", "char": "kirie", "body": "あの子供たちは成長する。変化する。私はしなかった。" },
    { "cmd": "text", "char": "saki", "body": "それって——寂しい？" },
    { "cmd": "sprite", "char": "kirie", "pose": "normal", "position": "left" },
    { "cmd": "text", "char": "kirie", "body": "……その変数は、今まで検証したことがなかった。今は——わからない。" },
    { "cmd": "text", "char": "narrator", "body": "サキは何も言わなかった。ただ、キリエの隣に座った。" },
    { "cmd": "text", "char": "narrator", "body": "二人はしばらく、子供たちを見ていた。" },
    { "cmd": "text", "char": "saki", "body": "アイス食べよ。" },
    { "cmd": "text", "char": "kirie", "body": "アイス。" },
    { "cmd": "text", "char": "saki", "body": "冷たいお菓子。好きなの選んでいいよ。" },
    { "cmd": "text", "char": "narrator", "body": "キリエはしばらく売店のケースを見た。サキはソーダ味を選んだ。キリエはいちごを選んだ。" },
    { "cmd": "text", "char": "kirie", "body": "……甘い。" },
    { "cmd": "text", "char": "saki", "body": "そりゃそうでしょ。" },
    { "cmd": "sprite", "char": "kirie", "pose": "anxious", "position": "left" },
    { "cmd": "text", "char": "narrator", "body": "キリエは少しずつ食べていた。甘すぎる。しかし言わなかった。" },
    { "cmd": "text", "char": "narrator", "body": "目が、泳いでいた。" },
    { "cmd": "sprite", "char": "saki", "pose": "smile", "position": "right" },
    { "cmd": "text", "char": "narrator", "body": "サキがすぐ気づいた。" },
    { "cmd": "text", "char": "narrator", "body": "無言でソーダ味を差し出した。" },
    { "cmd": "text", "char": "kirie", "body": "……なぜわかった。" },
    { "cmd": "text", "char": "saki", "body": "なんとなく。" },
    { "cmd": "text", "char": "kirie", "body": "……受け取る。" },
    { "cmd": "text", "char": "narrator", "body": "アイスを交換した。キリエはソーダを食べた。こちらのほうが、まだよかった。" },
    { "cmd": "text", "char": "kirie", "body": "……これは、許容できる。" },
    { "cmd": "text", "char": "saki", "body": "よかった。じゃ次からソーダね。" },
    { "cmd": "text", "char": "kirie", "body": "次がある前提か。" },
    { "cmd": "text", "char": "saki", "body": "あるよ。また来よ、ここ。" },
    { "cmd": "sprite", "char": "kirie", "pose": "normal", "position": "left" },
    { "cmd": "text", "char": "kirie", "body": "……わかった。" },
    { "cmd": "text", "char": "narrator", "body": "帰り道、キリエは少し静かだった。" },
    { "cmd": "text", "char": "narrator", "body": "街の音はまだ多かった。——さっきよりは、気にならなかった。" },
    { "cmd": "text", "char": "narrator", "body": "昼。" },
    { "cmd": "flag", "key": "CHAPTER09_COMPLETE", "value": "true" }
  ]
}
