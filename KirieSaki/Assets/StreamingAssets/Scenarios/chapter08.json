    { "cmd": "text", "char": "saki", "body": "変数だらけだよ。でもキリエ、ちゃんと電話対応しようとしてたじゃん。えらいじゃん。" },
    { "cmd": "text", "char": "kirie", "body": "……褒められた。" },
